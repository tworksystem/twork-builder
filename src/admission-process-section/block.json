{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/admission-process-section",
	"title": "Admission Process Section",
	"category": "twork-builder",
	"description": "Admission process section with step cards (Registration, During Stay, Discharge) for patient guide.",
	"keywords": [
		"admission",
		"process",
		"patient",
		"guide",
		"hospital",
		"twork"
	],
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"backgroundOverlay": {
			"type": "boolean",
			"default": false
		},
		"backgroundOverlayColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.5)"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 0.5
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"paddingTopMobile": {
			"type": "number",
			"default": 60
		},
		"paddingBottomMobile": {
			"type": "number",
			"default": 60
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "number",
			"default": 30
		},
		"gapMobile": {
			"type": "number",
			"default": 24
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Admission Process"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2.2
		},
		"sectionTitleFontSizeMobile": {
			"type": "number",
			"default": 1.8
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "center"
		},
		"showSectionSubtitle": {
			"type": "boolean",
			"default": true
		},
		"sectionSubtitle": {
			"type": "string",
			"default": "We ensure a smooth and hassle-free experience for our patients."
		},
		"sectionSubtitleColor": {
			"type": "string",
			"default": "#666666"
		},
		"sectionSubtitleFontSize": {
			"type": "number",
			"default": 1.05
		},
		"sectionSubtitleFontSizeMobile": {
			"type": "number",
			"default": 0.95
		},
		"sectionHeaderMaxWidth": {
			"type": "number",
			"default": 700
		},
		"sectionHeaderMarginBottom": {
			"type": "number",
			"default": 50
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"containerPaddingMobile": {
			"type": "number",
			"default": 20
		},
		"cardBorderRadius": {
			"type": "number",
			"default": 12
		},
		"cardBoxShadow": {
			"type": "boolean",
			"default": true
		},
		"cardBoxShadowColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.05)"
		},
		"cardBoxShadowHover": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.1)"
		},
		"cardBorderTopWidth": {
			"type": "number",
			"default": 4
		},
		"cardBorderTopColor": {
			"type": "string",
			"default": "#f48b2a"
		},
		"hoverEffect": {
			"type": "boolean",
			"default": true
		},
		"hoverTranslateY": {
			"type": "number",
			"default": -10
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationDelay": {
			"type": "number",
			"default": 100
		},
		"animationType": {
			"type": "string",
			"default": "fadeInUp"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#ffffff",
			"backgroundImage": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"backgroundOverlay": false,
			"backgroundOverlayColor": "rgba(0, 0, 0, 0.5)",
			"backgroundOverlayOpacity": 0.5,
			"paddingTop": 80,
			"paddingBottom": 80,
			"paddingTopMobile": 60,
			"paddingBottomMobile": 60,
			"columns": 3,
			"columnsTablet": 2,
			"columnsMobile": 1,
			"gap": 30,
			"gapMobile": 24,
			"showSectionTitle": true,
			"sectionTitle": "Admission Process",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2.2,
			"sectionTitleFontSizeMobile": 1.8,
			"sectionTitleFontWeight": 700,
			"sectionTitleAlignment": "center",
			"showSectionSubtitle": true,
			"sectionSubtitle": "We ensure a smooth and hassle-free experience for our patients.",
			"sectionSubtitleColor": "#666666",
			"sectionSubtitleFontSize": 1.05,
			"sectionSubtitleFontSizeMobile": 0.95,
			"sectionHeaderMaxWidth": 700,
			"sectionHeaderMarginBottom": 50,
			"containerMaxWidth": 1200,
			"containerPadding": 20,
			"containerPaddingMobile": 20,
			"cardBorderRadius": 12,
			"cardBoxShadow": true,
			"cardBoxShadowColor": "rgba(0, 0, 0, 0.05)",
			"cardBoxShadowHover": "rgba(0, 0, 0, 0.1)",
			"cardBorderTopWidth": 4,
			"cardBorderTopColor": "#f48b2a",
			"hoverEffect": true,
			"hoverTranslateY": -10,
			"animationOnScroll": true,
			"animationDelay": 100,
			"animationType": "fadeInUp"
		},
		"innerBlocks": [
			{
				"name": "twork/admission-process-item",
				"attributes": {
					"stepNumber": 1,
					"title": "Registration",
					"description": "Visit the admission counter at the lobby.",
					"listItems": [
						{
							"id": 1,
							"text": "Bring NRC / Passport"
						},
						{
							"id": 2,
							"text": "Insurance Card (if any)"
						},
						{
							"id": 3,
							"text": "Doctor's Admission Note"
						},
						{
							"id": 4,
							"text": "Initial Deposit"
						}
					]
				}
			},
			{
				"name": "twork/admission-process-item",
				"attributes": {
					"stepNumber": 2,
					"title": "During Stay",
					"description": "Our team will guide you to your room.",
					"listItems": [
						{
							"id": 1,
							"text": "24/7 Nursing Care"
						},
						{
							"id": 2,
							"text": "Daily Doctor Rounds"
						},
						{
							"id": 3,
							"text": "Dietitian Consultation"
						},
						{
							"id": 4,
							"text": "Room Amenities Guide"
						}
					]
				}
			},
			{
				"name": "twork/admission-process-item",
				"attributes": {
					"stepNumber": 3,
					"title": "Discharge",
					"description": "Complete the process before leaving.",
					"listItems": [
						{
							"id": 1,
							"text": "Final Bill Settlement"
						},
						{
							"id": 2,
							"text": "Collect Medical Reports"
						},
						{
							"id": 3,
							"text": "Take Home Medication"
						},
						{
							"id": 4,
							"text": "Follow-up Appointment"
						}
					]
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
