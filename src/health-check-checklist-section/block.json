{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/health-check-checklist-section",
    "version": "1.0.0",
    "title": "Checklist Section",
    "category": "twork-builder",
    "icon": "yes-alt",
    "description": "Two-column section: 'Are You Due for a Checkup?' checklist and image. Matches health-check-up.html.",
    "keywords": ["health", "checkup", "checklist", "chk", "twork"],
    "attributes": {
        "showSectionTitle": { "type": "boolean", "default": true },
        "sectionTitle": { "type": "string", "default": "Are You Due for a Checkup?" },
        "sectionTitleColor": { "type": "string", "default": "#005f73" },
        "sectionTitleFontSize": { "type": "number", "default": 2.5 },
        "sectionTitleFontWeight": { "type": "number", "default": 900 },
        "sectionTitleAlignment": { "type": "string", "default": "left" },
        "sectionTitleMarginBottom": { "type": "number", "default": 15 },
        "showSectionSubtitle": { "type": "boolean", "default": true },
        "sectionSubtitle": { "type": "string", "default": "If you check more than 2 boxes, it's time to book an appointment." },
        "sectionSubtitleColor": { "type": "string", "default": "#666666" },
        "sectionSubtitleFontSize": { "type": "number", "default": 1.1 },
        "sectionSubtitleFontWeight": { "type": "number", "default": 400 },
        "sectionSubtitleMarginBottom": { "type": "number", "default": 20 },
        "checklistItems": {
            "type": "array",
            "default": [
                "Has it been over a year since your last checkup?",
                "Do you feel tired or fatigued often?",
                "Is there a family history of diabetes/hypertension?",
                "Are you over 35 years old?",
                "Do you smoke or drink alcohol regularly?"
            ]
        },
        "imageUrl": { "type": "string", "default": "" },
        "imageId": { "type": "number" },
        "imageAlt": { "type": "string", "default": "Doctor" },
        "backgroundColor": { "type": "string", "default": "#f4f8fb" },
        "backgroundImage": { "type": "string", "default": "" },
        "backgroundImageId": { "type": "number" },
        "backgroundOverlay": { "type": "boolean", "default": false },
        "backgroundOverlayColor": { "type": "string", "default": "rgba(0, 0, 0, 0.5)" },
        "backgroundOverlayOpacity": { "type": "number", "default": 0.5 },
        "paddingTop": { "type": "number", "default": 90 },
        "paddingBottom": { "type": "number", "default": 90 },
        "containerMaxWidth": { "type": "number", "default": 1200 },
        "containerPadding": { "type": "number", "default": 20 },
        "gridGap": { "type": "number", "default": 50 },
        "boxBorderRadius": { "type": "number", "default": 20 },
        "boxPadding": { "type": "number", "default": 40 },
        "checkboxAccentColor": { "type": "string", "default": "#f48b2a" },
        "animationOnScroll": { "type": "boolean", "default": true },
        "animationDelay": { "type": "number", "default": 100 },
        "animationType": { "type": "string", "default": "fadeInUp" }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": ["wide", "full"]
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
