{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/accreditation-section",
    "version": "1.0.0",
    "title": "Accreditation Section",
    "category": "twork-builder",
    "icon": "awards",
    "description": "Professional accreditations and certifications grid with intro text, cert cards, and scroll animations.",
    "keywords": ["accreditation", "certification", "awards", "quality", "ISO", "JCI", "hospital", "twork"],
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "backgroundImage": {
            "type": "string",
            "default": ""
        },
        "backgroundImageId": {
            "type": "number"
        },
        "backgroundOverlay": {
            "type": "boolean",
            "default": false
        },
        "backgroundOverlayColor": {
            "type": "string",
            "default": "rgba(0, 0, 0, 0.5)"
        },
        "backgroundOverlayOpacity": {
            "type": "number",
            "default": 0.5
        },
        "paddingTop": {
            "type": "number",
            "default": 80
        },
        "paddingBottom": {
            "type": "number",
            "default": 80
        },
        "columns": {
            "type": "number",
            "default": 3
        },
        "columnsTablet": {
            "type": "number",
            "default": 2
        },
        "columnsMobile": {
            "type": "number",
            "default": 1
        },
        "gap": {
            "type": "number",
            "default": 30
        },
        "gridMarginTop": {
            "type": "number",
            "default": 60
        },
        "showIntroTitle": {
            "type": "boolean",
            "default": true
        },
        "introTitle": {
            "type": "string",
            "default": "Our Commitment to Quality"
        },
        "introTitleColor": {
            "type": "string",
            "default": "#212121"
        },
        "introTitleFontSize": {
            "type": "number",
            "default": 2.2
        },
        "introTitleFontWeight": {
            "type": "number",
            "default": 700
        },
        "introTitleAlignment": {
            "type": "string",
            "default": "center"
        },
        "showIntroContent": {
            "type": "boolean",
            "default": true
        },
        "introContent": {
            "type": "string",
            "default": "At Jivaka Hospital, we believe that quality healthcare is a fundamental right. Our relentless pursuit of excellence has been recognized by national and international bodies, ensuring that our patients receive world-class care in a safe environment."
        },
        "introContentColor": {
            "type": "string",
            "default": "#666666"
        },
        "introContentFontSize": {
            "type": "number",
            "default": 1.1
        },
        "introContentAlignment": {
            "type": "string",
            "default": "center"
        },
        "introMaxWidth": {
            "type": "number",
            "default": 800
        },
        "introMarginBottom": {
            "type": "number",
            "default": 60
        },
        "containerMaxWidth": {
            "type": "number",
            "default": 1200
        },
        "containerPadding": {
            "type": "number",
            "default": 30
        },
        "hoverEffect": {
            "type": "boolean",
            "default": true
        },
        "hoverTranslateY": {
            "type": "number",
            "default": -10
        },
        "hoverShadowIntensity": {
            "type": "number",
            "default": 1
        },
        "animationOnScroll": {
            "type": "boolean",
            "default": true
        },
        "animationType": {
            "type": "string",
            "default": "fadeInUp"
        },
        "animationDelay": {
            "type": "number",
            "default": 150
        }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": ["wide", "full"]
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "viewScript": "file:./view.js",
    "style": "file:./style-index.css"
}
