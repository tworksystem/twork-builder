{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/rad-step-item",
  "version": "1.0.0",
  "title": "Process Step",
  "parent": ["twork/rad-process-section"],
  "category": "twork-builder",
  "description": "Single workflow step (icon, title, description) for the Radiology Process Section.",
  "keywords": [
    "radiology",
    "process",
    "step",
    "twork"
  ],
  "attributes": {
    "iconClass": {
      "type": "string",
      "default": "far fa-calendar-check"
    },
    "title": {
      "type": "string",
      "default": "Book"
    },
    "description": {
      "type": "string",
      "default": "Schedule via phone or app."
    }
  },
  "supports": {
    "html": false
  },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}

