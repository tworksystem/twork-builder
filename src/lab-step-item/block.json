{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/lab-step-item",
	"version": "1.0.0",
	"title": "Step Item",
	"parent": [ "twork/lab-steps-section" ],
	"category": "twork-builder",
	"icon": "minus",
	"description": "Single step row (number + title and description) for Lab How It Works section.",
	"keywords": [ "lab", "step", "process", "how it works", "twork" ],
	"attributes": {
		"stepNumber": {
			"type": "string",
			"default": "1"
		},
		"title": {
			"type": "string",
			"default": "Book a Test"
		},
		"description": {
			"type": "string",
			"default": "Call us or book online."
		}
	},
	"supports": {
		"html": false
	},
	"example": {
		"attributes": {
			"stepNumber": "1",
			"title": "Book a Test",
			"description": "Call us or book online."
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
