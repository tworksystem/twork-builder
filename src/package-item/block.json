{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/package-item",
    "title": "Package Item",
    "parent": ["twork/packages-section"],
    "category": "twork-builder",
    "description": "Single package / pricing card for the packages section.",
    "attributes": {
        "category": {
            "type": "string",
            "default": "general"
        },
        "isRecommended": {
            "type": "boolean",
            "default": false
        },
        "ribbonText": {
            "type": "string",
            "default": "Best Value"
        },
        "packageName": {
            "type": "string",
            "default": "Package Name"
        },
        "packageNameColor": {
            "type": "string",
            "default": "#212121"
        },
        "packageNameFontSize": {
            "type": "number",
            "default": 1.3
        },
        "packageNameFontWeight": {
            "type": "number",
            "default": 900
        },
        "currency": {
            "type": "string",
            "default": "MMK"
        },
        "amount": {
            "type": "string",
            "default": "85,000"
        },
        "priceColor": {
            "type": "string",
            "default": "#f48b2a"
        },
        "amountFontSize": {
            "type": "number",
            "default": 3
        },
        "description": {
            "type": "string",
            "default": "Essential screening for young adults."
        },
        "descriptionColor": {
            "type": "string",
            "default": "#666666"
        },
        "descriptionFontSize": {
            "type": "number",
            "default": 0.9
        },
        "features": {
            "type": "array",
            "default": [
                { "text": "Feature one", "available": true },
                { "text": "Feature two", "available": true },
                { "text": "Unavailable feature", "available": false }
            ]
        },
        "featureTextColor": {
            "type": "string",
            "default": "#555555"
        },
        "featureUnavailableColor": {
            "type": "string",
            "default": "#999999"
        },
        "featureIconColor": {
            "type": "string",
            "default": "#2ecc71"
        },
        "featureFontSize": {
            "type": "number",
            "default": 0.95
        },
        "showButton": {
            "type": "boolean",
            "default": true
        },
        "buttonText": {
            "type": "string",
            "default": "Choose Plan"
        },
        "buttonUrl": {
            "type": "string",
            "default": "#"
        },
        "buttonTarget": {
            "type": "boolean",
            "default": false
        },
        "buttonRel": {
            "type": "string",
            "default": "noopener noreferrer"
        },
        "buttonStyle": {
            "type": "string",
            "default": "outline"
        },
        "buttonBgColor": {
            "type": "string",
            "default": "transparent"
        },
        "buttonTextColor": {
            "type": "string",
            "default": "#f48b2a"
        },
        "buttonBorderColor": {
            "type": "string",
            "default": "#f48b2a"
        },
        "buttonBorderRadius": {
            "type": "number",
            "default": 5
        },
        "buttonFontSize": {
            "type": "number",
            "default": 0.85
        },
        "buttonFontWeight": {
            "type": "number",
            "default": 700
        }
    },
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
