{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/contact-card",
	"title": "Contact Card",
	"parent": [
		"twork/contact-cards"
	],
	"description": "Single contact card item.",
	"keywords": [
		"contact",
		"card",
		"twork"
	],
	"attributes": {
		"iconUrl": {
			"type": "string",
			"default": ""
		},
		"iconId": {
			"type": "number"
		},
		"iconAlt": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": "Title"
		},
		"subtitle": {
			"type": "string",
			"default": ""
		},
		"contentType": {
			"type": "string",
			"default": "link"
		},
		"linkUrl": {
			"type": "string",
			"default": ""
		},
		"linkText": {
			"type": "string",
			"default": ""
		},
		"plainText": {
			"type": "string",
			"default": ""
		},
		"cardBgColor": {
			"type": "string",
			"default": "#eeebe8"
		}
	},
	"example": {
		"attributes": {
			"title": "Email",
			"subtitle": "Feel Free to Mail",
			"contentType": "link",
			"linkUrl": "mailto:hello@example.com",
			"linkText": "✉ hello@example.com",
			"plainText": "",
			"cardBgColor": "#eeebe8"
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js"
}
