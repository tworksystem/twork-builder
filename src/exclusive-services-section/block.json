{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/exclusive-services-section",
	"version": "1.0.0",
	"title": "Exclusive Services Section",
	"category": "twork-builder",
	"icon": "grid-view",
	"description": "Exclusive services section with icon cards (icon left, content right) for international patients.",
	"keywords": [
		"exclusive",
		"services",
		"international",
		"patient",
		"icon",
		"twork"
	],
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#f8f9fa"
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"backgroundOverlay": {
			"type": "boolean",
			"default": false
		},
		"backgroundOverlayColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.5)"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 0.5
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"paddingTopMobile": {
			"type": "number",
			"default": 60
		},
		"paddingBottomMobile": {
			"type": "number",
			"default": 60
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "number",
			"default": 25
		},
		"gapMobile": {
			"type": "number",
			"default": 20
		},
		"minColumnWidth": {
			"type": "number",
			"default": 280
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Exclusive Services"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2.2
		},
		"sectionTitleFontSizeMobile": {
			"type": "number",
			"default": 1.8
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "left"
		},
		"sectionTitleMarginBottom": {
			"type": "number",
			"default": 40
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"containerPaddingMobile": {
			"type": "number",
			"default": 20
		},
		"cardBorderRadius": {
			"type": "number",
			"default": 12
		},
		"hoverEffect": {
			"type": "boolean",
			"default": true
		},
		"hoverTranslateX": {
			"type": "number",
			"default": 5
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationDelay": {
			"type": "number",
			"default": 100
		},
		"animationType": {
			"type": "string",
			"default": "fadeInUp"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#f8f9fa",
			"backgroundImage": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"backgroundOverlay": false,
			"backgroundOverlayColor": "rgba(0, 0, 0, 0.5)",
			"backgroundOverlayOpacity": 0.5,
			"paddingTop": 80,
			"paddingBottom": 80,
			"paddingTopMobile": 60,
			"paddingBottomMobile": 60,
			"columns": 3,
			"columnsTablet": 2,
			"columnsMobile": 1,
			"gap": 25,
			"gapMobile": 20,
			"minColumnWidth": 280,
			"showSectionTitle": true,
			"sectionTitle": "Exclusive Services",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2.2,
			"sectionTitleFontSizeMobile": 1.8,
			"sectionTitleFontWeight": 700,
			"sectionTitleAlignment": "left",
			"sectionTitleMarginBottom": 40,
			"containerMaxWidth": 1200,
			"containerPadding": 20,
			"containerPaddingMobile": 20,
			"cardBorderRadius": 12,
			"hoverEffect": true,
			"hoverTranslateX": 5,
			"animationOnScroll": true,
			"animationDelay": 100,
			"animationType": "fadeInUp"
		},
		"innerBlocks": [
			{
				"name": "twork/exclusive-service-item",
				"attributes": {
					"icon": "fas fa-language",
					"title": "Language Interpretation",
					"description": "Our team speaks English, Chinese, and Thai to ensure clear communication."
				}
			},
			{
				"name": "twork/exclusive-service-item",
				"attributes": {
					"icon": "fas fa-plane-arrival",
					"title": "Airport Transfer",
					"description": "Complimentary pickup and drop-off services for patients and attendants."
				}
			},
			{
				"name": "twork/exclusive-service-item",
				"attributes": {
					"icon": "fas fa-passport",
					"title": "Visa Assistance",
					"description": "Provision of official documents required for Medical Visa application."
				}
			},
			{
				"name": "twork/exclusive-service-item",
				"attributes": {
					"icon": "fas fa-hotel",
					"title": "Accommodation",
					"description": "Partnerships with nearby hotels for comfortable stays for family members."
				}
			},
			{
				"name": "twork/exclusive-service-item",
				"attributes": {
					"icon": "fas fa-utensils",
					"title": "International Cuisine",
					"description": "Customized meal plans catering to diverse cultural and dietary preferences."
				}
			},
			{
				"name": "twork/exclusive-service-item",
				"attributes": {
					"icon": "fas fa-wifi",
					"title": "Connectivity",
					"description": "Free local SIM cards and high-speed Wi-Fi to keep you connected with home."
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
