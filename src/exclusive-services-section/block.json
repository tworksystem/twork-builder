{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/exclusive-services-section",
    "version": "1.0.0",
    "title": "Exclusive Services Section",
    "category": "twork-builder",
    "icon": "grid-view",
    "description": "Exclusive services section with icon cards (icon left, content right) for international patients.",
    "keywords": ["exclusive", "services", "international", "patient", "icon", "twork"],
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "#f8f9fa"
        },
        "backgroundImage": {
            "type": "string",
            "default": ""
        },
        "backgroundImageId": {
            "type": "number"
        },
        "backgroundOverlay": {
            "type": "boolean",
            "default": false
        },
        "backgroundOverlayColor": {
            "type": "string",
            "default": "rgba(0, 0, 0, 0.5)"
        },
        "backgroundOverlayOpacity": {
            "type": "number",
            "default": 0.5
        },
        "paddingTop": {
            "type": "number",
            "default": 80
        },
        "paddingBottom": {
            "type": "number",
            "default": 80
        },
        "paddingTopMobile": {
            "type": "number",
            "default": 60
        },
        "paddingBottomMobile": {
            "type": "number",
            "default": 60
        },
        "columns": {
            "type": "number",
            "default": 3
        },
        "columnsTablet": {
            "type": "number",
            "default": 2
        },
        "columnsMobile": {
            "type": "number",
            "default": 1
        },
        "gap": {
            "type": "number",
            "default": 25
        },
        "gapMobile": {
            "type": "number",
            "default": 20
        },
        "minColumnWidth": {
            "type": "number",
            "default": 280
        },
        "showSectionTitle": {
            "type": "boolean",
            "default": true
        },
        "sectionTitle": {
            "type": "string",
            "default": "Exclusive Services"
        },
        "sectionTitleColor": {
            "type": "string",
            "default": "#212121"
        },
        "sectionTitleFontSize": {
            "type": "number",
            "default": 2.2
        },
        "sectionTitleFontSizeMobile": {
            "type": "number",
            "default": 1.8
        },
        "sectionTitleFontWeight": {
            "type": "number",
            "default": 700
        },
        "sectionTitleAlignment": {
            "type": "string",
            "default": "left"
        },
        "sectionTitleMarginBottom": {
            "type": "number",
            "default": 40
        },
        "containerMaxWidth": {
            "type": "number",
            "default": 1200
        },
        "containerPadding": {
            "type": "number",
            "default": 20
        },
        "containerPaddingMobile": {
            "type": "number",
            "default": 20
        },
        "cardBorderRadius": {
            "type": "number",
            "default": 12
        },
        "hoverEffect": {
            "type": "boolean",
            "default": true
        },
        "hoverTranslateX": {
            "type": "number",
            "default": 5
        },
        "animationOnScroll": {
            "type": "boolean",
            "default": true
        },
        "animationDelay": {
            "type": "number",
            "default": 100
        },
        "animationType": {
            "type": "string",
            "default": "fadeInUp"
        }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": ["wide", "full"]
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
