{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/mission-vision-item",
	"version": "1.0.0",
	"title": "Mission / Vision Card",
	"category": "twork-builder",
	"icon": "heart",
	"description": "Single mission / vision / values card with icon, title and text.",
	"supports": {
		"html": false
	},
	"parent": [ "twork/mission-vision-grid" ],
	"attributes": {
		"iconClass": {
			"type": "string",
			"default": "fas fa-bullseye"
		},
		"iconType": {
			"type": "string",
			"default": ""
		},
		"iconValue": {
			"type": "string",
			"default": "dashicons-bullseye"
		},
		"iconImageUrl": {
			"type": "string",
			"default": ""
		},
		"iconImageId": {
			"type": "number"
		},
		"iconVideoUrl": {
			"type": "string",
			"default": ""
		},
		"iconVideoId": {
			"type": "number"
		},
		"iconVideoPosterUrl": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": "Our Mission"
		},
		"description": {
			"type": "string",
			"default": "Describe your mission, vision or values here."
		}
	},
	"example": {
		"attributes": {
			"iconClass": "fas fa-bullseye",
			"iconType": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"iconValue": "dashicons-bullseye",
			"iconImageUrl": "",
			"iconVideoUrl": "",
			"iconVideoPosterUrl": "",
			"title": "Our Mission",
			"description": "Describe your mission, vision or values here."
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./style-index.css"
}
