{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/gm-review-card",
	"title": "Review Card",
	"category": "twork-builder",
	"parent": [ "twork/gm-testimonials-section" ],
	"description": "Single patient review card (quote, text, reviewer name and label).",
	"attributes": {
		"quoteIcon": {
			"type": "string",
			"default": "fas fa-quote-left"
		},
		"reviewText": {
			"type": "string",
			"default": ""
		},
		"reviewerName": {
			"type": "string",
			"default": ""
		},
		"reviewerLabel": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	},
	"example": {
		"attributes": {
			"quoteIcon": "fas fa-quote-left",
			"reviewText": "",
			"reviewerName": "",
			"reviewerLabel": ""
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
