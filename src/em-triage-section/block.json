{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/em-triage-section",
    "version": "1.0.0",
    "title": "Triage Section",
    "category": "twork-builder",
    "icon": "list-view",
    "description": "When to Visit Emergency? triage section with header and triage cards (icon, title, list).",
    "keywords": ["emergency", "triage", "when to visit", "grid", "twork"],
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "paddingTop": {
            "type": "number",
            "default": 80
        },
        "paddingBottom": {
            "type": "number",
            "default": 80
        },
        "containerMaxWidth": {
            "type": "number",
            "default": 1280
        },
        "containerPadding": {
            "type": "number",
            "default": 20
        },
        "gap": {
            "type": "number",
            "default": 25
        },
        "minColumnWidth": {
            "type": "number",
            "default": 260
        },
        "showSectionHeader": {
            "type": "boolean",
            "default": true
        },
        "sectionTitle": {
            "type": "string",
            "default": "When to Visit Emergency?"
        },
        "sectionTitleColor": {
            "type": "string",
            "default": "#212121"
        },
        "sectionTitleFontSize": {
            "type": "number",
            "default": 2.5
        },
        "sectionTitleFontWeight": {
            "type": "number",
            "default": 700
        },
        "sectionSubtitle": {
            "type": "string",
            "default": "Recognizing the signs of a medical emergency can save lives. Seek immediate help if you observe:"
        },
        "sectionSubtitleColor": {
            "type": "string",
            "default": "#333333"
        },
        "sectionSubtitleFontSize": {
            "type": "number",
            "default": 1
        },
        "headerMaxWidth": {
            "type": "number",
            "default": 700
        },
        "headerMarginBottom": {
            "type": "number",
            "default": 50
        },
        "animationOnScroll": {
            "type": "boolean",
            "default": true
        },
        "animationType": {
            "type": "string",
            "default": "fade-up"
        }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": ["wide", "full"]
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
