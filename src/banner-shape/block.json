{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/banner-shape",
    "version": "1.0.0",
    "title": "Banner Shape",
    "category": "twork-builder",
    "icon": "cover-image",
    "description": "Professional banner with customizable background, overlay, and shape decoration using Jivaka theme colors.",
    "keywords": ["banner", "hero", "header", "shape", "twork"],
    "supports": {
        "html": false,
        "anchor": true,
        "align": ["full", "wide"]
    },
    "attributes": {
        "bannerHeading": {
            "type": "string",
            "default": "Welcome to Our Services"
        },
        "bannerDescription": {
            "type": "string",
            "default": "Professional healthcare services for your wellbeing"
        },
        "backgroundImage": {
            "type": "string",
            "default": ""
        },
        "backgroundImageId": {
            "type": "number"
        },
        "backgroundPositionX": {
            "type": "number",
            "default": 50
        },
        "backgroundPositionY": {
            "type": "number",
            "default": 50
        },
        "backgroundSize": {
            "type": "string",
            "default": "cover"
        },
        "minHeight": {
            "type": "number",
            "default": 500
        },
        "minHeightMobile": {
            "type": "number",
            "default": 350
        },
        "showOverlay": {
            "type": "boolean",
            "default": true
        },
        "overlayColor": {
            "type": "string",
            "default": "rgba(0, 0, 0, 0.3)"
        },
        "overlayOpacity": {
            "type": "number",
            "default": 0.3
        },
        "overlayGradient": {
            "type": "boolean",
            "default": true
        },
        "headingColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "headingFontSize": {
            "type": "number",
            "default": 3.5
        },
        "headingFontSizeMobile": {
            "type": "number",
            "default": 2.2
        },
        "headingFontWeight": {
            "type": "number",
            "default": 900
        },
        "headingTextShadow": {
            "type": "boolean",
            "default": true
        },
        "descriptionColor": {
            "type": "string",
            "default": "rgba(255, 255, 255, 0.95)"
        },
        "descriptionFontSize": {
            "type": "number",
            "default": 1.25
        },
        "descriptionFontSizeMobile": {
            "type": "number",
            "default": 1
        },
        "descriptionLineHeight": {
            "type": "number",
            "default": 1.8
        },
        "contentPadding": {
            "type": "number",
            "default": 60
        },
        "contentPaddingMobile": {
            "type": "number",
            "default": 40
        },
        "contentMaxWidth": {
            "type": "number",
            "default": 1200
        },
        "contentAlignment": {
            "type": "string",
            "default": "center"
        },
        "showShape": {
            "type": "boolean",
            "default": true
        },
        "shapeImage": {
            "type": "string",
            "default": ""
        },
        "shapeImageId": {
            "type": "number"
        },
        "shapeHeight": {
            "type": "number",
            "default": 150
        },
        "shapeHeightMobile": {
            "type": "number",
            "default": 100
        },
        "shapePosition": {
            "type": "string",
            "default": "bottom"
        },
        "shapeBackgroundSize": {
            "type": "string",
            "default": "cover"
        }
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
