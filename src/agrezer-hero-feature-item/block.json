{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/hero-feature",
	"version": "1.0.0",
	"title": "Hero Feature",
	"category": "twork-builder",
	"parent": [
		"twork/hero-section"
	],
	"icon": "star-filled",
	"description": "Hero feature item.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"title": {
			"type": "string",
			"default": "Healthy Soil<br>Solutions"
		},
		"iconVariant": {
			"type": "string",
			"default": "leaf"
		},
		"customIconUrl": {
			"type": "string",
			"default": ""
		},
		"customIconId": {
			"type": "number"
		},
		"customIconType": {
			"type": "string",
			"default": "image"
		},
		"badgeColor": {
			"type": "string",
			"default": "#8fbd45"
		},
		"iconColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"iconSize": {
			"type": "number",
			"default": 30
		},
		"iconOffsetX": {
			"type": "number",
			"default": 0
		},
		"iconOffsetY": {
			"type": "number",
			"default": 0
		},
		"enableHoverAnimation": {
			"type": "boolean",
			"default": false
		}
	},
	"example": {
		"attributes": {
			"title": "Healthy Soil<br>Solutions",
			"iconVariant": "leaf",
			"iconSize": 30,
			"iconOffsetX": 0,
			"iconOffsetY": 0,
			"enableHoverAnimation": false
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
