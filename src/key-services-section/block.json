{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/key-services-section",
	"version": "1.0.0",
	"title": "Key Services Section",
	"category": "twork-builder",
	"icon": "star-filled",
	"description": "A professional key services section with icon-based service items and comprehensive customization options.",
	"keywords": [ "services", "key", "features", "icons", "grid", "twork" ],
	"supports": {
		"html": false,
		"align": [ "full", "wide" ],
		"anchor": true
	},
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"backgroundOverlay": {
			"type": "boolean",
			"default": false
		},
		"backgroundOverlayColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.5)"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 0.5
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"paddingTopMobile": {
			"type": "number",
			"default": 60
		},
		"paddingBottomMobile": {
			"type": "number",
			"default": 60
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "number",
			"default": 30
		},
		"gapMobile": {
			"type": "number",
			"default": 30
		},
		"showBorder": {
			"type": "boolean",
			"default": false
		},
		"borderPosition": {
			"type": "string",
			"default": "vertical"
		},
		"borderColor": {
			"type": "string",
			"default": "#e0e0e0"
		},
		"borderColorHover": {
			"type": "string",
			"default": ""
		},
		"borderWidth": {
			"type": "number",
			"default": 0
		},
		"borderWidthMobile": {
			"type": "number",
			"default": 0
		},
		"disableAllBorders": {
			"type": "boolean",
			"default": true
		},
		"borderStyle": {
			"type": "string",
			"default": "solid"
		},
		"borderOpacity": {
			"type": "number",
			"default": 1
		},
		"showBorderDesktop": {
			"type": "boolean",
			"default": false
		},
		"showBorderTablet": {
			"type": "boolean",
			"default": false
		},
		"showBorderMobile": {
			"type": "boolean",
			"default": false
		},
		"sectionBorderWidth": {
			"type": "number",
			"default": 0
		},
		"sectionBorderColor": {
			"type": "string",
			"default": "#e0e0e0"
		},
		"sectionBorderStyle": {
			"type": "string",
			"default": "solid"
		},
		"sectionBorderRadius": {
			"type": "number",
			"default": 0
