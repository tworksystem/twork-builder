		"innerBlocks": [
			{
				"name": "twork/key-service-item",
				"attributes": {}
			},
			{
				"name": "twork/key-service-item",
				"attributes": {}
			},
			{
				"name": "twork/key-service-item",
				"attributes": {}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style-index.css"
}
