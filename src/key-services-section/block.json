		"sectionBoxShadow": {
			"type": "boolean",
			"default": false
		},
		"sectionBoxShadowColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.1)"
		},
		"sectionBoxShadowBlur": {
			"type": "number",
			"default": 10
		},
		"sectionBoxShadowSpread": {
			"type": "number",
			"default": 0
		},
		"sectionBoxShadowX": {
			"type": "number",
			"default": 0
		},
		"sectionBoxShadowY": {
			"type": "number",
			"default": 4
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 30
		},
		"containerPaddingMobile": {
			"type": "number",
			"default": 20
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": false
		},
		"sectionTitle": {
			"type": "string",
			"default": "Key Services"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2.5
		},
		"sectionTitleFontSizeMobile": {
			"type": "number",
			"default": 2
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "center"
		},
		"sectionTitleMarginBottom": {
			"type": "number",
			"default": 10
		},
		"showSectionSubtitle": {
			"type": "boolean",
			"default": false
		},
		"sectionSubtitle": {
			"type": "string",
			"default": "Our comprehensive healthcare services"
		},
		"sectionSubtitleColor": {
			"type": "string",
			"default": "#666666"
		},
		"sectionSubtitleFontSize": {
			"type": "number",
			"default": 1.1
		},
		"sectionSubtitleFontSizeMobile": {
			"type": "number",
			"default": 0.95
		},
		"sectionSubtitleFontWeight": {
			"type": "number",
			"default": 400
		},
		"sectionSubtitleMarginBottom": {
			"type": "number",
			"default": 50
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationDelay": {
			"type": "number",
			"default": 100
		},
		"animationType": {
			"type": "string",
			"default": "fadeInUp"
		},
		"hoverEffect": {
			"type": "boolean",
			"default": true
		},
		"hoverScale": {
			"type": "number",
			"default": 1.05
		},
		"hoverTranslateY": {
			"type": "number",
			"default": -5
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#ffffff",
			"backgroundImage": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"backgroundOverlay": false,
			"backgroundOverlayColor": "rgba(0, 0, 0, 0.5)",
			"backgroundOverlayOpacity": 0.5,
			"paddingTop": 80,
			"paddingBottom": 80,
			"paddingTopMobile": 60,
			"paddingBottomMobile": 60,
			"columns": 3,
			"columnsTablet": 2,
			"columnsMobile": 1,
			"gap": 30,
			"gapMobile": 30,
			"showBorder": false,
			"borderPosition": "vertical",
			"borderColor": "#e0e0e0",
			"borderColorHover": "",
			"borderWidth": 0,
			"borderWidthMobile": 0,
			"disableAllBorders": true,
			"borderStyle": "solid",
			"borderOpacity": 1,
			"showBorderDesktop": false,
			"showBorderTablet": false,
			"showBorderMobile": false,
			"sectionBorderWidth": 0,
			"sectionBorderColor": "#e0e0e0",
			"sectionBorderStyle": "solid",
			"sectionBorderRadius": 0,
			"sectionBoxShadow": false,
			"sectionBoxShadowColor": "rgba(0, 0, 0, 0.1)",
			"sectionBoxShadowBlur": 10,
			"sectionBoxShadowSpread": 0,
			"sectionBoxShadowX": 0,
			"sectionBoxShadowY": 4,
			"containerMaxWidth": 1200,
			"containerPadding": 30,
			"containerPaddingMobile": 20,
			"showSectionTitle": false,
			"sectionTitle": "Key Services",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2.5,
