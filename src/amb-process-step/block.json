{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/amb-process-step",
	"title": "Ambulance Process Step",
	"parent": [ "twork/amb-process-section" ],
	"category": "twork-builder",
	"description": "Single step in the emergency protocol (title + description). Number is auto-generated by CSS.",
	"keywords": [ "ambulance", "process", "step", "protocol", "twork" ],
	"attributes": {
		"title": {
			"type": "string",
			"default": "Call 1911"
		},
		"description": {
			"type": "string",
			"default": "Our dispatch center gathers location and patient condition."
		},
		"titleColor": {
			"type": "string",
			"default": "#0f172a"
		},
		"titleFontSize": {
			"type": "number",
			"default": 1.2
		},
		"titleFontWeight": {
			"type": "number",
			"default": 700
		},
		"titleMarginBottom": {
			"type": "number",
			"default": 10
		},
		"descriptionColor": {
			"type": "string",
			"default": "#666666"
		},
		"descriptionFontSize": {
			"type": "number",
			"default": 0.95
		},
		"stepPadding": {
			"type": "number",
			"default": 20
		}
	},
	"example": {
		"attributes": {
			"title": "Call 1911",
			"description": "Our dispatch center gathers location and patient condition.",
			"titleColor": "#0f172a",
			"titleFontSize": 1.2,
			"titleFontWeight": 700,
			"titleMarginBottom": 10,
			"descriptionColor": "#666666",
			"descriptionFontSize": 0.95,
			"stepPadding": 20
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js"
}
