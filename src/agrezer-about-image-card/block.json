{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/image-card",
	"version": "1.0.0",
	"title": "Image Card",
	"category": "twork-builder",
	"parent": [
		"twork/images-grid"
	],
	"icon": "format-image",
	"description": "Image card with overlay text and optional button.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"variant": {
			"type": "string",
			"default": "simple"
		},
		"mediaType": {
			"type": "string",
			"default": "image",
			"enum": [ "image", "video", "color" ]
		},
		"mediaUrl": {
			"type": "string",
			"default": ""
		},
		"mediaId": {
			"type": "number"
		},
		"mediaAlt": {
			"type": "string",
			"default": ""
		},
		"videoAutoplay": {
			"type": "boolean",
			"default": true
		},
		"videoLoop": {
			"type": "boolean",
			"default": true
		},
		"videoMuted": {
			"type": "boolean",
			"default": true
		},
		"videoControls": {
			"type": "boolean",
			"default": false
		},
		"backgroundColor": {
			"type": "string",
			"default": "#9db37a"
		},
		"objectFit": {
			"type": "string",
			"default": "cover",
			"enum": [ "cover", "contain", "fill" ]
		},
		"overlayText": {
			"type": "string",
			"default": "Agriculture nurtures life through organic growth, sustainable farming."
		},
		"overlayButtonText": {
			"type": "string",
			"default": "About Us"
		},
		"overlayButtonUrl": {
			"type": "string",
			"default": "#"
		},
		"showButtonIcon": {
			"type": "boolean",
			"default": true
		},
		"buttonIconType": {
			"type": "string",
			"default": "diagonal-arrow"
		}
	},
	"example": {
		"attributes": {
			"variant": "overlay",
			"mediaType": "image",
			"mediaUrl": "https://images.unsplash.com/photo-1472653431158-6364773b2a56?auto=format&fit=crop&w=1400&q=80",
			"mediaAlt": "Farmer inspecting healthy crops",
			"objectFit": "cover",
			"overlayText": "Agriculture nurtures life through organic growth, sustainable farming, and careful stewardship of the land.",
			"overlayButtonText": "About Us",
			"overlayButtonUrl": "#",
			"showButtonIcon": true,
			"buttonIconType": "diagonal-arrow"
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js"
}
