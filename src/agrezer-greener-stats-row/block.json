{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/stats-row",
	"version": "1.0.0",
	"title": "Stats Row",
	"category": "twork-builder",
	"parent": [
		"twork/highlights-section"
	],
	"icon": "chart-bar",
	"description": "Row/grid container for stat items.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"example": {
		"innerBlocks": [
			{
				"name": "twork/stat-item",
				"attributes": {
					"iconVariant": "growth",
					"title": "80% Pure Growth",
					"description": "Measured gains in plant vigor and stand uniformity across pilot fields.",

					"statNumber": "80%",
					"statLabel": "Pure Growth",
					"numberColor": "#f48b2a",
					"labelColor": "#212121",
					"labelTextTransform": "uppercase"
				}
			},
			{
				"name": "twork/stat-item",
				"attributes": {
					"iconVariant": "organic",
					"title": "95% Organic Roots",
					"description": "Partners certified for organic handling and cold-chain integrity.",

					"statNumber": "95%",
					"statLabel": "Organic Roots",
					"numberColor": "#f48b2a",
					"labelColor": "#212121",
					"labelTextTransform": "uppercase"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js"
}
