{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/team-member",
	"version": "1.0.0",
	"title": "Team Member",
	"category": "twork-builder",
	"icon": "businessperson",
	"description": "Professional team member display with Twork standards.",
	"supports": {
		"html": false,
		"anchor": true,
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"name": {
			"type": "string",
			"source": "html",
			"selector": ".twork-team-member__name"
		},
		"role": {
			"type": "string",
			"default": "Team Member"
		},
		"accentColor": {
			"type": "string",
			"default": "#f48b2a"
		}
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"role": "Team Member",
			"accentColor": "#f48b2a"
		}
	}
}
