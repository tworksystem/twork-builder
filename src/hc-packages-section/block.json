{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/hc-packages-section",
	"version": "1.0.0",
	"title": "Packages Section",
	"category": "twork-builder",
	"icon": "grid-view",
	"description": "Care Packages section: header + grid of package cards. Matches home-care.html.",
	"keywords": [ "home care", "packages", "pricing", "plans", "twork" ],
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"paddingTop": {
			"type": "number",
			"default": 60
		},
		"paddingBottom": {
			"type": "number",
			"default": 60
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Care Packages"
		},
		"sectionSubtitle": {
			"type": "string",
			"default": "Affordable plans for long-term recovery."
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionSubtitleColor": {
			"type": "string",
			"default": "#555555"
		},
		"gap": {
			"type": "number",
			"default": 30
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationType": {
			"type": "string",
			"default": "fade-up"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#ffffff",
			"paddingTop": 60,
			"paddingBottom": 60,
			"containerMaxWidth": 1200,
			"containerPadding": 20,
			"showSectionTitle": true,
			"sectionTitle": "Care Packages",
			"sectionSubtitle": "Affordable plans for long-term recovery.",
			"sectionTitleColor": "#212121",
			"sectionSubtitleColor": "#555555",
			"gap": 30,
			"animationOnScroll": true,
			"animationType": "fade-up"
		},
		"innerBlocks": [
			{
				"name": "twork/hc-package-card",
				"attributes": {
					"title": "Nursing (Short Term)",
					"price": "30,000",
					"priceUnit": "MMK / Day",
					"features": [
						"12 Hours Duty",
						"Vitals Monitoring",
						"Medication Administration",
						"Basic Hygiene Care"
					],
					"buttonText": "Choose Plan",
					"buttonUrl": "#",
					"buttonStyle": "outline"
				}
			},
			{
				"name": "twork/hc-package-card",
				"attributes": {
					"title": "Physio Recovery",
					"price": "25,000",
					"priceUnit": "MMK / Session",
					"features": [
						"45-60 Mins Session",
						"Manual Therapy",
						"Exercise Guidance",
						"Pain Management"
					],
					"buttonText": "Choose Plan",
					"buttonUrl": "#",
					"buttonStyle": "primary",
					"headBackground": "var(--hc-light)"
				}
			},
			{
				"name": "twork/hc-package-card",
				"attributes": {
					"title": "Doctor Visit",
					"price": "40,000",
					"priceUnit": "MMK / Visit",
					"features": [
						"Comprehensive Checkup",
						"Prescription Review",
						"Specialist Referral (if needed)",
						"Dietary Advice"
					],
					"buttonText": "Choose Plan",
					"buttonUrl": "#",
					"buttonStyle": "outline"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
