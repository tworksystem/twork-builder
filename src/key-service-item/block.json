		"buttonText": {
			"type": "string",
			"default": "Learn More"
		},
		"buttonUrl": {
			"type": "string",
			"default": "#"
		},
		"buttonTarget": {
			"type": "boolean",
			"default": false
		},
		"buttonRel": {
			"type": "string",
			"default": "noopener noreferrer"
		},
