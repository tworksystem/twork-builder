{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/features-section",
	"version": "1.0.0",
	"title": "Features Section (About)",
	"category": "twork-builder",
	"icon": "grid-view",
	"description": "About section with a grid of feature cards (icon, title, description). Matches general-surgery about block.",
	"keywords": [ "features", "about", "grid", "twork" ],
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"sectionId": {
			"type": "string",
			"default": "about"
		},
		"containerClass": {
			"type": "string",
			"default": "container"
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "number",
			"default": 30
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 24
		},
		"gridMinItemWidth": {
			"type": "number",
			"default": 260
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"sectionId": "about",
			"containerClass": "container",
			"columns": 3,
			"columnsTablet": 2,
			"columnsMobile": 1,
			"gap": 30,
			"containerMaxWidth": 1200,
			"containerPadding": 24,
			"gridMinItemWidth": 260
		},
		"innerBlocks": [
			{
				"name": "twork/feature-card",
				"attributes": {
					"title": "Advanced Tech",
					"description": "4K Laparoscopy towers and modern modular operation theaters.",
					"iconClass": "fas fa-microscope"
				}
			},
			{
				"name": "twork/feature-card",
				"attributes": {
					"title": "Expert Team",
					"description": "Senior consultants with over 20 years of surgical experience.",
					"iconClass": "fas fa-user-md"
				}
			},
			{
				"name": "twork/feature-card",
				"attributes": {
					"title": "Patient Centric",
					"description": "Personalized care plans ensuring comfort and safety.",
					"iconClass": "fas fa-heart-pulse"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
