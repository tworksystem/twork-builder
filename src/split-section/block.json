{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/split-section",
	"version": "1.0.0",
	"title": "Split Section (Laparoscopy / Keyhole)",
	"category": "twork-builder",
	"icon": "layout",
	"description": "Two-column split: left (label, title, description, list, CTA button), right (image + floating badge). Matches general-surgery laparoscopic block.",
	"keywords": [ "split", "laparoscopy", "keyhole", "two-column", "twork" ],
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"sectionClass": {
			"type": "string",
			"default": "section-padding split-section"
		},
		"label": {
			"type": "string",
			"default": "Minimally Invasive"
		},
		"title": {
			"type": "string",
			"default": "Laparoscopic Surgery"
		},
		"description": {
			"type": "string",
			"default": "Also known as Keyhole Surgery. We use tiny incisions and cameras to perform complex operations, resulting in significantly less pain and scarring."
		},
		"listItems": {
			"type": "array",
			"default": []
		},
		"buttonText": {
			"type": "string",
			"default": "Learn about Keyhole"
		},
		"buttonUrl": {
			"type": "string",
			"default": "#"
		},
		"buttonTarget": {
			"type": "boolean",
			"default": false
		},
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"badgeIcon": {
			"type": "string",
			"default": "fas fa-star"
		},
		"badgeTitle": {
			"type": "string",
			"default": "Gold Standard"
		},
		"badgeSubtitle": {
			"type": "string",
			"default": "Safety Protocols"
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 24
		},
		"gridGap": {
			"type": "number",
			"default": 60
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"sectionClass": "section-padding split-section",
			"label": "Minimally Invasive",
			"title": "Laparoscopic Surgery",
			"description": "Also known as Keyhole Surgery. We use tiny incisions and cameras to perform complex operations, resulting in significantly less pain and scarring.",
			"listItems": [],
			"buttonText": "Learn about Keyhole",
			"buttonUrl": "#",
			"buttonTarget": false,
			"imageUrl": "",
			"imageAlt": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"badgeIcon": "fas fa-star",
			"badgeTitle": "Gold Standard",
			"badgeSubtitle": "Safety Protocols",
			"containerMaxWidth": 1200,
			"containerPadding": 24,
			"gridGap": 60
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
