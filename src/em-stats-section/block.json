{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/em-stats-section",
	"version": "1.0.0",
	"title": "Stats Section",
	"category": "twork-builder",
	"icon": "chart-bar",
	"description": "24/7 emergency quick stats bar with icon, value and label items (em-stats).",
	"keywords": [ "emergency", "stats", "24/7", "grid", "twork" ],
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#f48b2a"
		},
		"paddingTop": {
			"type": "number",
			"default": 40
		},
		"paddingBottom": {
			"type": "number",
			"default": 40
		},
		"marginTop": {
			"type": "number",
			"default": -50
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1280
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"gap": {
			"type": "number",
			"default": 20
		},
		"borderRadius": {
			"type": "number",
			"default": 16
		},
		"boxShadow": {
			"type": "boolean",
			"default": true
		},
		"boxShadowColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.08)"
		},
		"boxShadowBlur": {
			"type": "number",
			"default": 30
		},
		"boxShadowSpread": {
			"type": "number",
			"default": 0
		},
		"boxShadowOffsetX": {
			"type": "number",
			"default": 0
		},
		"boxShadowOffsetY": {
			"type": "number",
			"default": 10
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationType": {
			"type": "string",
			"default": "fade-up"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#f48b2a",
			"paddingTop": 40,
			"paddingBottom": 40,
			"marginTop": -50,
			"containerMaxWidth": 1280,
			"containerPadding": 20,
			"gap": 20,
			"borderRadius": 16,
			"boxShadow": true,
			"boxShadowColor": "rgba(0, 0, 0, 0.08)",
			"boxShadowBlur": 30,
			"boxShadowSpread": 0,
			"boxShadowOffsetX": 0,
			"boxShadowOffsetY": 10,
			"animationOnScroll": true,
			"animationType": "fade-up"
		},
		"innerBlocks": [
			{
				"name": "twork/em-stat-item",
				"attributes": {
					"iconClass": "fas fa-clock",
					"statValue": "24/7",
					"statLabel": "Open All Day"
				}
			},
			{
				"name": "twork/em-stat-item",
				"attributes": {
					"iconClass": "fas fa-user-md",
					"statValue": "10+",
					"statLabel": "ER Specialists"
				}
			},
			{
				"name": "twork/em-stat-item",
				"attributes": {
					"iconClass": "fas fa-ambulance",
					"statValue": "15 min",
					"statLabel": "Avg. Response"
				}
			},
			{
				"name": "twork/em-stat-item",
				"attributes": {
					"iconClass": "fas fa-bed",
					"statValue": "20+",
					"statLabel": "ICU Beds"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
