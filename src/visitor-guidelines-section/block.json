{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/visitor-guidelines-section",
    "title": "Visitor Guidelines Section",
    "category": "twork-builder",
    "description": "Visitor guidelines section with Do's and Don'ts columns for patient guide.",
    "keywords": ["visitor", "guidelines", "dos", "donts", "patient", "guide", "twork"],
    "icon": "list-view",
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "backgroundImage": {
            "type": "string",
            "default": ""
        },
        "backgroundImageId": {
            "type": "number"
        },
        "backgroundOverlay": {
            "type": "boolean",
            "default": false
        },
        "backgroundOverlayColor": {
            "type": "string",
            "default": "rgba(0, 0, 0, 0.5)"
        },
        "backgroundOverlayOpacity": {
            "type": "number",
            "default": 0.5
        },
        "paddingTop": {
            "type": "number",
            "default": 80
        },
        "paddingBottom": {
            "type": "number",
            "default": 80
        },
        "paddingTopMobile": {
            "type": "number",
            "default": 60
        },
        "paddingBottomMobile": {
            "type": "number",
            "default": 60
        },
        "columns": {
            "type": "number",
            "default": 2
        },
        "columnsMobile": {
            "type": "number",
            "default": 1
        },
        "gap": {
            "type": "number",
            "default": 40
        },
        "gapMobile": {
            "type": "number",
            "default": 30
        },
        "showSectionTitle": {
            "type": "boolean",
            "default": true
        },
        "sectionTitle": {
            "type": "string",
            "default": "Visitor Guidelines"
        },
        "sectionTitleColor": {
            "type": "string",
            "default": "#212121"
        },
        "sectionTitleFontSize": {
            "type": "number",
            "default": 2
        },
        "sectionTitleFontSizeMobile": {
            "type": "number",
            "default": 1.6
        },
        "sectionTitleFontWeight": {
            "type": "number",
            "default": 700
        },
        "sectionTitleAlignment": {
            "type": "string",
            "default": "center"
        },
        "sectionHeaderMarginBottom": {
            "type": "number",
            "default": 50
        },
        "containerMaxWidth": {
            "type": "number",
            "default": 1200
        },
        "containerPadding": {
            "type": "number",
            "default": 20
        },
        "containerPaddingMobile": {
            "type": "number",
            "default": 20
        },
        "animationOnScroll": {
            "type": "boolean",
            "default": true
        },
        "animationDelay": {
            "type": "number",
            "default": 100
        },
        "animationType": {
            "type": "string",
            "default": "fadeInUp"
        }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": ["wide", "full"]
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
