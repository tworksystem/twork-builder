{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/gm-services-section",
    "version": "1.0.0",
    "title": "Services Section",
    "category": "twork-builder",
    "icon": "grid-view",
    "description": "General Medicine services grid with title, subtitle and responsive cards.",
    "keywords": ["general medicine", "services", "grid", "twork"],
    "supports": {
        "html": false,
        "align": ["wide", "full"]
    },
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "paddingTop": {
            "type": "number",
            "default": 100
        },
        "paddingBottom": {
            "type": "number",
            "default": 100
        },
        "containerMaxWidth": {
            "type": "number",
            "default": 1200
        },
        "containerPadding": {
            "type": "number",
            "default": 24
        },
        "showSectionTitle": {
            "type": "boolean",
            "default": true
        },
        "sectionTitle": {
            "type": "string",
            "default": "Our General Medicine Services"
        },
        "sectionSubtitle": {
            "type": "string",
            "default": "We treat a wide range of acute and chronic conditions with a focus on preventative care and long-term health."
        },
        "sectionTitleColor": {
            "type": "string",
            "default": "#212121"
        },
        "sectionSubtitleColor": {
            "type": "string",
            "default": "#555555"
        },
        "sectionTitleAlignment": {
            "type": "string",
            "default": "center"
        },
        "sectionTitleFontSize": {
            "type": "number",
            "default": 2.5
        },
        "sectionSubtitleFontSize": {
            "type": "number",
            "default": 1.1
        },
        "gridGap": {
            "type": "number",
            "default": 30
        }
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}

