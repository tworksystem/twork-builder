{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/tele-process-section",
    "version": "1.0.0",
    "title": "Process Section",
    "category": "twork-builder",
    "icon": "list-view",
    "description": "How It Works process section with step cards (icon, title, description).",
    "keywords": ["telemedicine", "process", "how it works", "steps", "twork"],
    "attributes": {
        "sectionPaddingTop": {
            "type": "number",
            "default": 80
        },
        "sectionPaddingBottom": {
            "type": "number",
            "default": 80
        },
        "containerMaxWidth": {
            "type": "number",
            "default": 1200
        },
        "containerPadding": {
            "type": "number",
            "default": 24
        },
        "gridGap": {
            "type": "number",
            "default": 30
        },
        "minItemWidth": {
            "type": "number",
            "default": 240
        },
        "sectionAnchor": {
            "type": "string",
            "default": "how-it-works"
        },
        "backgroundColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "showSectionTitle": {
            "type": "boolean",
            "default": false
        },
        "sectionTitle": {
            "type": "string",
            "default": "How It Works"
        },
        "sectionSubtitle": {
            "type": "string",
            "default": ""
        },
        "sectionTitleColor": {
            "type": "string",
            "default": "#212121"
        },
        "sectionSubtitleColor": {
            "type": "string",
            "default": "#555555"
        },
        "sectionTitleAlignment": {
            "type": "string",
            "default": "center"
        },
        "sectionTitleFontSize": {
            "type": "number",
            "default": 2.5
        },
        "sectionSubtitleFontSize": {
            "type": "number",
            "default": 1.1
        },
        "sectionHeaderMarginBottom": {
            "type": "number",
            "default": 50
        },
        "useHeaderFadeUp": {
            "type": "boolean",
            "default": true
        }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": ["wide", "full"]
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
