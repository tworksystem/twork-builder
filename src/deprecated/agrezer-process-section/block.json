{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/agrezer-process-section",
	"version": "1.0.0",
	"title": "Agrezer Process Section",
	"category": "twork-builder",
	"icon": "randomize",
	"description": "Three-column process layout: step, center image, step (Agrezer).",
	"keywords": [ "process", "steps", "agriculture", "agrezer", "twork" ],
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#f4f4f4"
		},
		"paddingTop": {
			"type": "number",
			"default": 86
		},
		"paddingBottom": {
			"type": "number",
			"default": 96
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1240
		},
		"containerGutter": {
			"type": "number",
			"default": 24
		},
		"gridGap": {
			"type": "number",
			"default": 32
		},
		"taglineIcon": {
			"type": "string",
			"default": "🌿"
		},
		"taglineText": {
			"type": "string",
			"default": "Agri Intelligence"
		},
		"sectionTitle": {
			"type": "string",
			"default": "From Soil to Soul, We Grow Naturally"
		},
		"taglineColor": {
			"type": "string",
			"default": "#2d352b"
		},
		"taglineIconColor": {
			"type": "string",
			"default": "#8fbd45"
		},
		"titleColor": {
			"type": "string",
			"default": "#16191d"
		},
		"titleFontSize": {
			"type": "number",
			"default": 2.75
		},
		"titleFontWeight": {
			"type": "number",
			"default": 700
		},
		"wreathDecorationUrl": {
			"type": "string",
			"default": ""
		},
		"wreathDecorationId": {
			"type": "number"
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#f4f4f4",
			"paddingTop": 86,
			"paddingBottom": 96,
			"containerMaxWidth": 1240,
			"containerGutter": 24,
			"gridGap": 32,
			"taglineIcon": "🌿",
			"taglineText": "Agri Intelligence",
			"sectionTitle": "From Soil to Soul, We Grow Naturally",
			"taglineColor": "#2d352b",
			"taglineIconColor": "#8fbd45",
			"titleColor": "#16191d",
			"titleFontSize": 2.75,
			"titleFontWeight": 700
		},
		"innerBlocks": [
			{
				"name": "twork/agrezer-process-step",
				"attributes": {
					"position": "left",
					"badgeNum": "01",
					"stepTitle": "Data-Driven Agriculture",
					"stepText": "Soil maps, weather stations, and satellite indices guide every input decision.",
					"showCta": true,
					"ctaText": "More Details",
					"ctaUrl": "#"
				}
			},
			{
				"name": "twork/agrezer-process-center",
				"attributes": {
					"image": "https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=900&q=80",
					"alt": "Circular farming process diagram placeholder",
					"maxWidth": 520
				}
			},
			{
				"name": "twork/agrezer-process-step",
				"attributes": {
					"position": "right",
					"badgeNum": "02",
					"stepTitle": "Planting & Establishment",
					"stepText": "Variety selection, seed treatment, and planting windows matched to field conditions.",
					"showCta": false,
					"ctaText": "More Details",
					"ctaUrl": "#"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
