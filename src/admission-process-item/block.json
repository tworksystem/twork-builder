{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/admission-process-item",
    "title": "Admission Process Item",
    "parent": ["twork/admission-process-section"],
    "description": "Single step card for the admission process (e.g. Registration, During Stay, Discharge).",
    "keywords": ["admission", "process", "step", "card", "twork"],
    "attributes": {
        "stepNumber": {
            "type": "number",
            "default": 1
        },
        "title": {
            "type": "string",
            "default": "Registration"
        },
        "titleColor": {
            "type": "string",
            "default": "#212121"
        },
        "titleFontSize": {
            "type": "number",
            "default": 1.3
        },
        "titleFontWeight": {
            "type": "number",
            "default": 700
        },
        "description": {
            "type": "string",
            "default": "Visit the admission counter at the lobby."
        },
        "descriptionColor": {
            "type": "string",
            "default": "#666666"
        },
        "descriptionFontSize": {
            "type": "number",
            "default": 0.95
        },
        "listItems": {
            "type": "array",
            "default": [
                { "id": 1, "text": "Bring NRC / Passport" },
                { "id": 2, "text": "Insurance Card (if any)" },
                { "id": 3, "text": "Doctor's Admission Note" },
                { "id": 4, "text": "Initial Deposit" }
            ]
        },
        "listItemColor": {
            "type": "string",
            "default": "#555555"
        },
        "listItemFontSize": {
            "type": "number",
            "default": 0.95
        },
        "iconColor": {
            "type": "string",
            "default": "#f48b2a"
        },
        "stepNumberBgColor": {
            "type": "string",
            "default": "#f48b2a"
        },
        "stepNumberTextColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "stepNumberSize": {
            "type": "number",
            "default": 50
        },
        "cardPadding": {
            "type": "number",
            "default": 40
        },
        "cardPaddingMobile": {
            "type": "number",
            "default": 30
        }
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
