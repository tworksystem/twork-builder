{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/how-it-works-section",
    "version": "1.0.0",
    "title": "How It Works Section",
    "category": "twork-builder",
    "icon": "editor-ol",
    "description": "Process / How It Works steps section with numbered rows, ideal for lab tests, departments, or service flows.",
    "keywords": [
        "how it works",
        "process",
        "steps",
        "flow",
        "twork"
    ],
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "#fafafa"
        },
        "backgroundImage": {
            "type": "string",
            "default": ""
        },
        "backgroundImageId": {
            "type": "number"
        },
        "backgroundOverlay": {
            "type": "boolean",
            "default": false
        },
        "backgroundOverlayColor": {
            "type": "string",
            "default": "rgba(0, 0, 0, 0.5)"
        },
        "backgroundOverlayOpacity": {
            "type": "number",
            "default": 0.5
        },
        "paddingTop": {
            "type": "number",
            "default": 80
        },
        "paddingBottom": {
            "type": "number",
            "default": 80
        },
        "columns": {
            "type": "number",
            "default": 1
        },
        "columnsTablet": {
            "type": "number",
            "default": 1
        },
        "columnsMobile": {
            "type": "number",
            "default": 1
        },
        "gap": {
            "type": "number",
            "default": 24
        },
        "showSectionTitle": {
            "type": "boolean",
            "default": true
        },
        "sectionTitle": {
            "type": "string",
            "default": "How It Works"
        },
        "sectionTitleColor": {
            "type": "string",
            "default": "#111827"
        },
        "sectionTitleFontSize": {
            "type": "number",
            "default": 2.1
        },
        "sectionTitleFontWeight": {
            "type": "number",
            "default": 700
        },
        "sectionTitleAlignment": {
            "type": "string",
            "default": "left"
        },
        "showSectionSubtitle": {
            "type": "boolean",
            "default": false
        },
        "sectionSubtitle": {
            "type": "string",
            "default": ""
        },
        "sectionSubtitleColor": {
            "type": "string",
            "default": "#6b7280"
        },
        "sectionSubtitleFontSize": {
            "type": "number",
            "default": 1.0
        },
        "sectionHeaderMaxWidth": {
            "type": "number",
            "default": 640
        },
        "sectionHeaderMarginBottom": {
            "type": "number",
            "default": 32
        },
        "containerMaxWidth": {
            "type": "number",
            "default": 1200
        },
        "containerPadding": {
            "type": "number",
            "default": 24
        },
        "hoverEffect": {
            "type": "boolean",
            "default": true
        },
        "hoverTranslateY": {
            "type": "number",
            "default": -4
        },
        "animationOnScroll": {
            "type": "boolean",
            "default": true
        },
        "animationDelay": {
            "type": "number",
            "default": 100
        },
        "animationType": {
            "type": "string",
            "default": "fadeInUp"
        }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": [
            "wide",
            "full"
        ]
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}

