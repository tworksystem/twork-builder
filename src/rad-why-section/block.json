{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/rad-why-section",
  "version": "1.0.0",
  "title": "Why Choose Section",
  "category": "twork-builder",
  "icon": "awards",
  "description": "Radiology & Imaging \u201cWhy Choose Jivaka Imaging?\u201d section with icon grid cards.",
  "keywords": [
    "radiology",
    "imaging",
    "why choose",
    "icons",
    "twork"
  ],
  "attributes": {
    "backgroundColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "paddingTop": {
      "type": "number",
      "default": 80
    },
    "paddingBottom": {
      "type": "number",
      "default": 80
    },
    "containerMaxWidth": {
      "type": "number",
      "default": 1200
    },
    "containerPadding": {
      "type": "number",
      "default": 20
    },
    "columns": {
      "type": "number",
      "default": 4
    },
    "columnsTablet": {
      "type": "number",
      "default": 2
    },
    "columnsMobile": {
      "type": "number",
      "default": 1
    },
    "gap": {
      "type": "number",
      "default": 30
    },
    "showSectionTitle": {
      "type": "boolean",
      "default": true
    },
    "sectionTitle": {
      "type": "string",
      "default": "Why Choose Jivaka Imaging?"
    },
    "sectionTitleColor": {
      "type": "string",
      "default": "#212121"
    },
    "sectionTitleFontSize": {
      "type": "number",
      "default": 2.5
    },
    "sectionTitleFontWeight": {
      "type": "number",
      "default": 700
    },
    "sectionTitleAlignment": {
      "type": "string",
      "default": "center"
    },
    "showSectionSubtitle": {
      "type": "boolean",
      "default": true
    },
    "sectionSubtitle": {
      "type": "string",
      "default": "We combine technology with expertise to deliver results you can trust."
    },
    "sectionSubtitleColor": {
      "type": "string",
      "default": "#666666"
    },
    "sectionSubtitleFontSize": {
      "type": "number",
      "default": 1.1
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}

