{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/phy-facilities-section",
  "version": "1.0.0",
  "title": "Facilities Section",
  "category": "twork-builder",
  "icon": "images-alt2",
  "description": "Physiotherapy facilities slider – cards loaded from WordPress posts (featured image, title, excerpt). Matches physiotherapy-rehab.html facilities section.",
  "keywords": ["physio", "facilities", "slider", "gym", "twork"],
  "attributes": {
    "source": {
      "type": "string",
      "default": "recent"
    },
    "categoryId": {
      "type": "number",
      "default": 0
    },
    "numberOfItems": {
      "type": "number",
      "default": 4
    },
    "orderBy": {
      "type": "string",
      "default": "date"
    },
    "order": {
      "type": "string",
      "default": "DESC"
    },
    "backgroundColor": {
      "type": "string",
      "default": "#fdfdfd"
    },
    "paddingTop": {
      "type": "number",
      "default": 80
    },
    "paddingBottom": {
      "type": "number",
      "default": 80
    },
    "containerMaxWidth": {
      "type": "number",
      "default": 1280
    },
    "containerPadding": {
      "type": "number",
      "default": 24
    },
    "showSectionHeader": {
      "type": "boolean",
      "default": true
    },
    "sectionTitle": {
      "type": "string",
      "default": "Our Facilities"
    },
    "sectionSubtitle": {
      "type": "string",
      "default": "Fully equipped gym and therapy rooms."
    },
    "headerAlign": {
      "type": "string",
      "default": "center"
    },
    "headerMaxWidth": {
      "type": "number",
      "default": 700
    },
    "cardWidth": {
      "type": "number",
      "default": 350
    },
    "imageHeight": {
      "type": "number",
      "default": 220
    },
    "gap": {
      "type": "number",
      "default": 20
    },
    "animationOnScroll": {
      "type": "boolean",
      "default": true
    },
    "staggerClass": {
      "type": "string",
      "default": "stagger-up"
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"]
  },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}

