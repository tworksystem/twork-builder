{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/team-member-item",
	"title": "Team Member Item",
	"parent": [ "twork/team-members-grid" ],
	"description": "Single team member card with image, name, position, bio, specializations, contact, social links, and CTA button.",
	"keywords": [ "team", "member", "specialist", "doctor", "twork" ],
