			"default": false
		},
		"imageOverlayColor": {
			"type": "string",
			"default": "rgba(244, 139, 42, 0.8)"
		},
		"imageOverlayOpacity": {
			"type": "number",
			"default": 0.8
		},
		"memberName": {
			"type": "string",
			"default": "Dr. John Doe"
		},
		"memberNameColor": {
			"type": "string",
			"default": "#212121"
		},
		"memberNameFontSize": {
			"type": "number",
			"default": 1.5
