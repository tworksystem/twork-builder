{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/phy-faq-section",
  "version": "1.0.0",
  "title": "FAQ Section",
  "category": "twork-builder",
  "icon": "editor-help",
  "description": "Common Questions section with accordion items, matching physiotherapy-rehab.html.",
  "keywords": ["physio", "faq", "questions", "accordion", "twork"],
  "attributes": {
    "backgroundColor": { "type": "string", "default": "transparent" },
    "paddingTop":      { "type": "number", "default": 60 },
    "paddingBottom":   { "type": "number", "default": 80 },
    "containerMaxWidth": { "type": "number", "default": 1280 },
    "containerPadding":  { "type": "number", "default": 24 },

    "showSectionTitle": { "type": "boolean", "default": true },
    "sectionTitle":     { "type": "string",  "default": "Common Questions" },
    "headerAlign":      { "type": "string",  "default": "center" },

    "contentMaxWidth":  { "type": "number", "default": 800 },
    "animationOnScroll": { "type": "boolean", "default": true },
    "animationType":    { "type": "string",  "default": "fade-up" },
    "animationDelay":   { "type": "number",  "default": 100 }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"]
  },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}

