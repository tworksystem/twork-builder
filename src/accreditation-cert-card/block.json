{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/accreditation-cert-card",
	"title": "Accreditation Cert Card",
	"parent": [ "twork/accreditation-section" ],
	"description": "Single accreditation/certification card with icon, title, badge, and description.",
	"keywords": [
		"accreditation",
		"certificate",
		"ISO",
		"JCI",
		"card",
		"twork"
	],
	"attributes": {
		"iconClass": {
			"type": "string",
			"default": "fas fa-certificate"
		},
		"certTitle": {
			"type": "string",
			"default": "ISO 9001:2015"
		},
		"certBadge": {
			"type": "string",
			"default": "Certified Since 2018"
		},
		"certDescription": {
			"type": "string",
			"default": "Recognized for our Quality Management System ensuring consistent and excellent healthcare services."
		},
		"iconColor": {
			"type": "string",
			"default": "#f48b2a"
		},
		"iconSize": {
			"type": "number",
			"default": 2.5
		},
		"iconBgColor": {
			"type": "string",
			"default": "#f8f9fa"
		},
		"titleColor": {
			"type": "string",
			"default": "#212121"
		},
		"titleFontSize": {
			"type": "number",
			"default": 1.3
		},
		"titleFontWeight": {
			"type": "number",
			"default": 700
		},
		"badgeBgColor": {
			"type": "string",
			"default": "#fff3e0"
		},
		"badgeTextColor": {
			"type": "string",
			"default": "#f48b2a"
		},
		"badgeFontSize": {
			"type": "number",
			"default": 0.8
		},
		"badgeFontWeight": {
			"type": "number",
			"default": 700
		},
		"badgeBorderRadius": {
			"type": "number",
			"default": 20
		},
		"descriptionColor": {
			"type": "string",
			"default": "#666666"
		},
		"descriptionFontSize": {
			"type": "number",
			"default": 0.95
		},
		"descriptionLineHeight": {
			"type": "number",
			"default": 1.6
		},
		"cardPadding": {
			"type": "number",
			"default": 40
		},
		"cardPaddingHorizontal": {
			"type": "number",
			"default": 30
		},
		"cardBorderRadius": {
			"type": "number",
			"default": 12
		},
		"cardBorderColor": {
			"type": "string",
			"default": "#eee"
		},
		"cardBorderWidth": {
			"type": "number",
			"default": 1
		},
		"cardBgColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"showTopBarOnHover": {
			"type": "boolean",
			"default": true
		},
		"topBarColor": {
			"type": "string",
			"default": "#f48b2a"
		}
	},
	"example": {
		"attributes": {
			"iconClass": "fas fa-certificate",
			"certTitle": "ISO 9001:2015",
			"certBadge": "Certified Since 2018",
			"certDescription": "Recognized for our Quality Management System ensuring consistent and excellent healthcare services.",
			"iconColor": "#f48b2a",
			"iconSize": 2.5,
			"iconBgColor": "#f8f9fa",
			"titleColor": "#212121",
			"titleFontSize": 1.3,
			"titleFontWeight": 700,
			"badgeBgColor": "#fff3e0",
			"badgeTextColor": "#f48b2a",
			"badgeFontSize": 0.8,
			"badgeFontWeight": 700,
			"badgeBorderRadius": 20,
			"descriptionColor": "#666666",
			"descriptionFontSize": 0.95,
			"descriptionLineHeight": 1.6,
			"cardPadding": 40,
			"cardPaddingHorizontal": 30,
			"cardBorderRadius": 12,
			"cardBorderColor": "#eee",
			"cardBorderWidth": 1,
			"cardBgColor": "#ffffff",
			"showTopBarOnHover": true,
			"topBarColor": "#f48b2a"
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
