{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/services-grid",
	"version": "1.0.0",
	"title": "Services Grid",
	"category": "twork-builder",
	"icon": "grid-view",
	"description": "A professional services grid container with customizable layout and styling options.",
	"supports": {
		"html": false,
		"align": [ "full", "wide" ]
	},
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#f9f9f9"
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"columns": {
			"type": "number",
			"default": 4
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"gap": {
			"type": "number",
			"default": 0
		},
		"borderRadius": {
			"type": "number",
			"default": 12
		},
		"boxShadow": {
			"type": "boolean",
			"default": true
		},
		"boxShadowColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.08)"
		},
		"boxShadowBlur": {
			"type": "number",
			"default": 32
		},
		"boxShadowSpread": {
			"type": "number",
			"default": 0
		},
		"boxShadowOffsetX": {
			"type": "number",
			"default": 0
		},
		"boxShadowOffsetY": {
			"type": "number",
			"default": 8
		},
		"hoverEffect": {
			"type": "boolean",
			"default": true
		},
		"hoverTranslateY": {
			"type": "number",
			"default": -4
		},
		"hoverScale": {
			"type": "number",
			"default": 1
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationDelay": {
			"type": "number",
			"default": 100
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 30
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Our Services"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2.5
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "center"
		},
		"sectionTitleMarginBottom": {
			"type": "number",
			"default": 10
		},
		"showSectionSubtitle": {
			"type": "boolean",
			"default": true
		},
		"sectionSubtitle": {
			"type": "string",
			"default": "Professional healthcare services for your wellbeing"
		},
		"sectionSubtitleColor": {
			"type": "string",
			"default": "#666666"
		},
		"sectionSubtitleFontSize": {
			"type": "number",
			"default": 1.1
		},
		"sectionSubtitleFontWeight": {
			"type": "number",
			"default": 400
		},
		"sectionSubtitleMarginBottom": {
			"type": "number",
			"default": 50
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"backgroundOverlay": {
			"type": "boolean",
			"default": false
		},
		"backgroundOverlayColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.5)"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 0.5
		},
		"animationType": {
			"type": "string",
			"default": "fadeInUp"
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#f9f9f9",
			"paddingTop": 80,
			"paddingBottom": 80,
			"columns": 4,
			"columnsMobile": 1,
			"columnsTablet": 2,
			"gap": 0,
			"borderRadius": 12,
			"boxShadow": true,
			"boxShadowColor": "rgba(0, 0, 0, 0.08)",
			"boxShadowBlur": 32,
			"boxShadowSpread": 0,
			"boxShadowOffsetX": 0,
			"boxShadowOffsetY": 8,
			"hoverEffect": true,
			"hoverTranslateY": -4,
			"hoverScale": 1,
			"animationOnScroll": true,
			"animationDelay": 100,
			"containerMaxWidth": 1200,
			"containerPadding": 30,
			"showSectionTitle": true,
			"sectionTitle": "Our Services",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2.5,
			"sectionTitleFontWeight": 700,
			"sectionTitleAlignment": "center",
			"sectionTitleMarginBottom": 10,
			"showSectionSubtitle": true,
			"sectionSubtitle": "Professional healthcare services for your wellbeing",
			"sectionSubtitleColor": "#666666",
			"sectionSubtitleFontSize": 1.1,
			"sectionSubtitleFontWeight": 400,
			"sectionSubtitleMarginBottom": 50,
			"backgroundImage": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"backgroundOverlay": false,
			"backgroundOverlayColor": "rgba(0, 0, 0, 0.5)",
			"backgroundOverlayOpacity": 0.5,
			"animationType": "fadeInUp"
		},
		"innerBlocks": [
			{
				"name": "twork/service-item",
				"attributes": {
					"cardStyle": "primary"
				}
			},
			{
				"name": "twork/service-item",
				"attributes": {
					"cardStyle": "primary"
				}
			},
			{
				"name": "twork/service-item",
				"attributes": {
					"cardStyle": "primary"
				}
			},
			{
				"name": "twork/service-item",
				"attributes": {
					"cardStyle": "dark",
					"itemType": "info"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
