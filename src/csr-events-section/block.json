{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/csr-events-section",
	"version": "1.0.0",
	"title": "Events List Section",
	"category": "twork-builder",
	"icon": "calendar-alt",
	"description": "Upcoming CSR Events section with event cards - date, title, location, time, and CTA button.",
	"keywords": [ "csr", "events", "upcoming", "calendar", "twork" ],
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#f8f9fa"
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Upcoming CSR Events"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2.2
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "center"
		},
		"sectionTitleMarginBottom": {
			"type": "number",
			"default": 20
		},
		"showSectionSubtitle": {
			"type": "boolean",
			"default": true
		},
		"sectionSubtitle": {
			"type": "string",
			"default": "Join us in our upcoming missions to serve the community."
		},
		"sectionSubtitleColor": {
			"type": "string",
			"default": "#666666"
		},
		"sectionSubtitleFontSize": {
			"type": "number",
			"default": 1.1
		},
		"sectionSubtitleMarginBottom": {
			"type": "number",
			"default": 40
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 30
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationDelay": {
			"type": "number",
			"default": 100
		},
		"paddingTopMobile": {
			"type": "number",
			"default": 60
		},
		"paddingBottomMobile": {
			"type": "number",
			"default": 60
		},
		"containerPaddingMobile": {
			"type": "number",
			"default": 20
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#f8f9fa",
			"paddingTop": 80,
			"paddingBottom": 80,
			"showSectionTitle": true,
			"sectionTitle": "Upcoming CSR Events",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2.2,
			"sectionTitleFontWeight": 700,
			"sectionTitleAlignment": "center",
			"sectionTitleMarginBottom": 20,
			"showSectionSubtitle": true,
			"sectionSubtitle": "Join us in our upcoming missions to serve the community.",
			"sectionSubtitleColor": "#666666",
			"sectionSubtitleFontSize": 1.1,
			"sectionSubtitleMarginBottom": 40,
			"containerMaxWidth": 1200,
			"containerPadding": 30,
			"animationOnScroll": true,
			"animationDelay": 100,
			"paddingTopMobile": 60,
			"paddingBottomMobile": 60,
			"containerPaddingMobile": 20
		},
		"innerBlocks": [
			{
				"name": "twork/csr-event-item",
				"attributes": {
					"dateDay": "15",
					"dateMonth": "Nov",
					"title": "Free Eye Check-up Camp",
					"location": "Kyaukse Township",
					"time": "8:00 AM – 4:00 PM",
					"buttonText": "Volunteer"
				}
			},
			{
				"name": "twork/csr-event-item",
				"attributes": {
					"dateDay": "05",
					"dateMonth": "Dec",
					"title": "Annual Blood Donation Drive",
					"location": "Jivaka Hospital Main Hall",
					"time": "9:00 AM – 3:00 PM",
					"buttonText": "Register"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
