{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/paediatrics-conditions-section",
  "version": "1.0.0",
  "title": "Conditions Section",
  "category": "twork-builder",
  "icon": "grid-view",
  "description": "Conditions We Treat section with header and grid of condition cards. Matches paediatrics-centre.html.",
  "keywords": ["paediatrics", "conditions", "grid", "twork"],
  "attributes": {
    "backgroundColor": { "type": "string", "default": "#ffffff" },
    "paddingTop": { "type": "number", "default": 80 },
    "paddingBottom": { "type": "number", "default": 80 },
    "containerMaxWidth": { "type": "number", "default": 1200 },
    "containerPadding": { "type": "number", "default": 20 },
    "showSectionHeader": { "type": "boolean", "default": true },
    "sectionTitle": { "type": "string", "default": "Conditions We Treat" },
    "sectionSubtitle": { "type": "string", "default": "Expert care for a wide range of common and complex childhood conditions." },
    "sectionTitleColor": { "type": "string", "default": "#212121" },
    "sectionSubtitleColor": { "type": "string", "default": "#666666" },
    "sectionTitleFontSize": { "type": "number", "default": 2.2 },
    "sectionSubtitleFontSize": { "type": "number", "default": 1.05 },
    "minColumnWidth": { "type": "number", "default": 220 },
    "gap": { "type": "number", "default": 20 },
    "animationOnScroll": { "type": "boolean", "default": true }
  },
  "supports": { "html": false, "anchor": true, "align": ["wide", "full"] },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}
