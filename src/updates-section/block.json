{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/updates-section",
	"version": "1.0.0",
	"title": "Posts / Updates Section",
	"category": "twork-builder",
	"icon": "megaphone",
	"description": "Hospital News & Updates – displays WordPress posts in a card grid. Select by category or show latest posts.",
	"keywords": [ "news", "updates", "posts", "blog", "hospital", "twork" ],
	"attributes": {
		"source": {
			"type": "string",
			"default": "recent"
		},
		"categoryId": {
			"type": "number",
			"default": 0
		},
		"postIds": {
			"type": "array",
			"default": []
		},
		"numberOfItems": {
			"type": "number",
			"default": 3
		},
		"orderBy": {
			"type": "string",
			"default": "date"
		},
		"order": {
			"type": "string",
			"default": "DESC"
		},
		"backgroundColor": {
			"type": "string",
			"default": "#f9f9f9"
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Hospital News & Updates"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2.5
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "center"
		},
		"sectionTitleMarginBottom": {
			"type": "number",
			"default": 10
		},
		"showSectionSubtitle": {
			"type": "boolean",
			"default": true
		},
		"sectionSubtitle": {
			"type": "string",
			"default": "Read our latest articles and stay informed."
		},
		"sectionSubtitleColor": {
			"type": "string",
			"default": "#666666"
		},
		"sectionSubtitleFontSize": {
			"type": "number",
			"default": 1.1
		},
		"sectionSubtitleMarginBottom": {
			"type": "number",
			"default": 50
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 30
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "number",
			"default": 30
		},
		"imageHeight": {
			"type": "number",
			"default": 200
		},
		"contentPadding": {
			"type": "number",
			"default": 20
		},
		"metaColor": {
			"type": "string",
			"default": "#666666"
		},
		"metaFontSize": {
			"type": "number",
			"default": 0.9
		},
		"titleFontSize": {
			"type": "number",
			"default": 1.3
		},
		"excerptFontSize": {
			"type": "number",
			"default": 1
		},
		"readMoreLabel": {
			"type": "string",
			"default": "Read More →"
		},
		"readMoreColor": {
			"type": "string",
			"default": "#f48b2a"
		},
		"hoverEffect": {
			"type": "boolean",
			"default": true
		},
		"hoverTranslateY": {
			"type": "number",
			"default": -5
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationType": {
			"type": "string",
			"default": "fadeInUp"
		},
		"animationDelay": {
			"type": "number",
			"default": 100
		},
		"showBlogLink": {
			"type": "boolean",
			"default": false
		},
		"blogLinkText": {
			"type": "string",
			"default": "View All on Blog"
		},
		"blogLinkUrl": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"source": "recent",
			"categoryId": 0,
			"postIds": [],
			"numberOfItems": 3,
			"orderBy": "date",
			"order": "DESC",
			"backgroundColor": "#f9f9f9",
			"paddingTop": 80,
			"paddingBottom": 80,
			"showSectionTitle": true,
			"sectionTitle": "Hospital News & Updates",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2.5,
			"sectionTitleFontWeight": 700,
			"sectionTitleAlignment": "center",
			"sectionTitleMarginBottom": 10,
			"showSectionSubtitle": true,
			"sectionSubtitle": "Read our latest articles and stay informed.",
			"sectionSubtitleColor": "#666666",
			"sectionSubtitleFontSize": 1.1,
			"sectionSubtitleMarginBottom": 50,
			"containerMaxWidth": 1200,
			"containerPadding": 30,
			"columns": 3,
			"columnsTablet": 2,
			"columnsMobile": 1,
			"gap": 30,
			"imageHeight": 200,
			"contentPadding": 20,
			"metaColor": "#666666",
			"metaFontSize": 0.9,
			"titleFontSize": 1.3,
			"excerptFontSize": 1,
			"readMoreLabel": "Read More →",
			"readMoreColor": "#f48b2a",
			"hoverEffect": true,
			"hoverTranslateY": -5,
			"animationOnScroll": true,
			"animationType": "fadeInUp",
			"animationDelay": 100,
			"showBlogLink": false,
			"blogLinkText": "View All on Blog",
			"blogLinkUrl": ""
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style-index.css"
}
