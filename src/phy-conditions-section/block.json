{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/phy-conditions-section",
  "version": "1.0.0",
  "title": "Conditions Section",
  "category": "twork-builder",
  "icon": "forms",
  "description": "Conditions We Treat section: header + three condition columns, matching physiotherapy-rehab.html.",
  "keywords": ["physio", "conditions", "body map", "treat", "twork"],
  "attributes": {
    "backgroundColor": { "type": "string", "default": "#f9f9f9" },
    "paddingTop":      { "type": "number", "default": 60 },
    "paddingBottom":   { "type": "number", "default": 80 },
    "containerMaxWidth": { "type": "number", "default": 1280 },
    "containerPadding":  { "type": "number", "default": 24 },

    "showSectionTitle":    { "type": "boolean", "default": true },
    "sectionTitle":        { "type": "string",  "default": "Conditions We Treat" },
    "showSectionSubtitle": { "type": "boolean", "default": true },
    "sectionSubtitle":     { "type": "string",  "default": "Targeted therapy for every part of your body." },
    "headerAlign":         { "type": "string",  "default": "center" },

    "gap":                { "type": "number", "default": 30 },
    "animationOnScroll":  { "type": "boolean", "default": true },
    "animationType":      { "type": "string",  "default": "fade-up" },
    "animationDelay":     { "type": "number",  "default": 100 }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"]
  },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}

