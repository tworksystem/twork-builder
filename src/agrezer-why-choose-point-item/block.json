{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/benefit-point",
	"version": "1.0.0",
	"title": "Benefit Point",
	"category": "twork-builder",
	"parent": [
		"twork/benefits-section"
	],
	"icon": "marker",
	"description": "Numbered point item positioned on a stage.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"slot": {
			"type": "number",
			"default": 1
		},
		"badgeText": {
			"type": "string",
			"default": "01"
		},
		"pointText": {
			"type": "string",
			"default": ""
		}
	},
	"example": {
		"attributes": {
			"slot": 1,
			"badgeText": "01",
			"pointText": "Health From the Earth — nutrient-rich soil and transparent sourcing."
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js"
}
