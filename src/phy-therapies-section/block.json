{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/phy-therapies-section",
  "version": "1.0.0",
  "title": "Therapies Section",
  "category": "twork-builder",
  "icon": "grid-view",
  "description": "Our Therapies section: header + expandable therapy cards, matching physiotherapy-rehab.html.",
  "keywords": ["physio", "therapies", "services", "cards", "twork"],
  "attributes": {
    "backgroundColor": { "type": "string", "default": "transparent" },
    "paddingTop":      { "type": "number", "default": 60 },
    "paddingBottom":   { "type": "number", "default": 80 },
    "containerMaxWidth": { "type": "number", "default": 1280 },
    "containerPadding":  { "type": "number", "default": 24 },

    "showSectionTitle":    { "type": "boolean", "default": true },
    "sectionTitle":        { "type": "string",  "default": "Our Therapies" },
    "showSectionSubtitle": { "type": "boolean", "default": true },
    "sectionSubtitle":     { "type": "string",  "default": "A multimodal approach to faster recovery." },
    "headerAlign":         { "type": "string",  "default": "center" },

    "gap":                { "type": "number", "default": 20 },
    "animationOnScroll":  { "type": "boolean", "default": true },
    "animationType":      { "type": "string",  "default": "fade-up" },
    "animationDelay":     { "type": "number",  "default": 100 }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"]
  },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}

