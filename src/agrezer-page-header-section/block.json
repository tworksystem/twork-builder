{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/page-header",
	"version": "1.0.0",
	"title": "Page Header",
	"category": "twork-builder",
	"icon": "heading",
	"description": "Page header with title, background, and breadcrumb.",
	"keywords": [
		"breadcrumb",
		"header",
		"banner",
		"title",
		"twork"
	],
	"supports": {
		"html": false,
		"align": [
			"full",
			"wide"
		],
		"anchor": true
	},
	"attributes": {
		"title": {
			"type": "string",
			"default": "About Us"
		},
		"backgroundType": {
			"type": "string",
			"default": "image"
		},
		"backgroundVideo": {
			"type": "string",
			"default": ""
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"backgroundColor": {
			"type": "string",
			"default": "#0c2614"
		},
		"overlayOpacity": {
			"type": "number",
			"default": 85
		},
		"titleColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"titleFontSize": {
			"type": "number",
			"default": 72
		},
		"breadcrumbColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"breadcrumbActiveColor": {
			"type": "string",
			"default": "#8bc34a"
		},
		"backgroundPosition": {
			"type": "string",
			"default": "center center"
		},
		"overlayColor": {
			"type": "string",
			"default": "rgba(12, 38, 20, 0.85)"
		},
		"graphicImage": {
			"type": "string",
			"default": ""
		},
		"graphicImageId": {
			"type": "number"
		},
		"graphicAlt": {
			"type": "string",
			"default": ""
		},
		"graphicMaxWidth": {
			"type": "number",
			"default": 420
		},
		"breadcrumbs": {
			"type": "array",
			"default": [
				{
					"label": "Home",
					"url": "/"
				},
				{
					"label": "About Us",
					"url": ""
				}
			]
		},
		"separatorChar": {
			"type": "string",
			"default": "•"
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerWidthPct": {
			"type": "number",
			"default": 90
		},
		"paddingTop": {
			"type": "number",
			"default": 180
		},
		"paddingBottom": {
			"type": "number",
			"default": 100
		},
		"containerMinHeight": {
			"type": "number",
			"default": 180
		},
		"enableTractorAnimation": {
			"type": "boolean",
			"default": true
		},
		"fallbackBgColor": {
			"type": "string",
			"default": "#0c2614"
		},
		"hasMigratedLegacyBg": {
			"type": "boolean",
			"default": false
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"title": "About Our Farm",
			"backgroundType": "image",
			"backgroundImage": "https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=2000&q=80",
			"backgroundVideo": "",
			"backgroundColor": "#0c2614",
			"overlayOpacity": 82,
			"titleColor": "#ffffff",
			"titleFontSize": 72,
			"breadcrumbColor": "#ffffff",
			"breadcrumbActiveColor": "#8bc34a",
			"backgroundPosition": "center center",
			"overlayColor": "rgba(12, 38, 20, 0.82)",
			"graphicImage": "https://images.unsplash.com/photo-1592982537447-7440770cbfc9?auto=format&fit=crop&w=800&q=80",
			"graphicAlt": "Tractor illustration",
			"graphicMaxWidth": 380,
			"breadcrumbs": [
				{
					"label": "Home",
					"url": "/"
				},
				{
					"label": "About",
					"url": "/about/"
				},
				{
					"label": "Our Farm",
					"url": ""
				}
			],
			"separatorChar": "•",
			"containerMaxWidth": 1200,
			"containerWidthPct": 90,
			"paddingTop": 160,
			"paddingBottom": 88,
			"containerMinHeight": 180,
			"enableTractorAnimation": true,
			"fallbackBgColor": "#0c2614"
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
