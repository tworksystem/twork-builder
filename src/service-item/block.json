{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "twork/service-item",
    "title": "Service Item",
    "parent": ["twork/services-grid"],
    "attributes": {
        "itemType": {
            "type": "string",
            "default": "card"
        },
        "cardStyle": {
            "type": "string",
            "default": "primary"
        },
        "customBgColor": {
            "type": "string",
            "default": ""
        },
        "customTextColor": {
            "type": "string",
            "default": ""
        },
        "gradientStart": {
            "type": "string",
            "default": "#f48b2a"
        },
        "gradientEnd": {
            "type": "string",
            "default": "#e67a22"
        },
        "gradientAngle": {
            "type": "number",
            "default": 135
        },
        "image": {
            "type": "string",
            "default": ""
        },
        "imageId": {
            "type": "number"
        },
        "imageHeight": {
            "type": "number",
            "default": 260
        },
        "imageObjectFit": {
            "type": "string",
            "default": "cover"
        },
        "imageObjectPosition": {
            "type": "string",
            "default": "center"
        },
        "metaText": {
            "type": "string",
            "default": "Advanced Care"
        },
        "metaColor": {
            "type": "string",
            "default": ""
        },
        "metaFontSize": {
            "type": "number",
            "default": 0.75
        },
        "metaTextTransform": {
            "type": "string",
            "default": "uppercase"
        },
        "title": {
            "type": "string",
            "default": "Service Title"
        },
        "titleColor": {
            "type": "string",
            "default": ""
        },
        "titleFontSize": {
            "type": "number",
            "default": 1.6
        },
        "titleFontWeight": {
            "type": "number",
            "default": 700
        },
        "description": {
            "type": "string",
            "default": "Service description goes here..."
        },
        "descriptionColor": {
            "type": "string",
            "default": ""
        },
        "descriptionFontSize": {
            "type": "number",
            "default": 0.9
        },
        "showButton": {
            "type": "boolean",
            "default": true
        },
        "buttonText": {
            "type": "string",
            "default": "Learn More"
        },
        "buttonUrl": {
            "type": "string",
            "default": "#"
        },
        "buttonTarget": {
            "type": "boolean",
            "default": false
        },
        "buttonRel": {
            "type": "string",
            "default": "noopener noreferrer"
        },
        "buttonStyle": {
            "type": "string",
            "default": "default"
        },
        "buttonBgColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "buttonTextColor": {
            "type": "string",
            "default": "#f48b2a"
        },
        "buttonBorderRadius": {
            "type": "number",
            "default": 22
        },
        "buttonPaddingVertical": {
            "type": "number",
            "default": 12
        },
        "buttonPaddingHorizontal": {
            "type": "number",
            "default": 28
        },
        "buttonFontSize": {
            "type": "number",
            "default": 0.85
        },
        "buttonFontWeight": {
            "type": "number",
            "default": 600
        },
        "buttonTextTransform": {
            "type": "string",
            "default": "uppercase"
        },
        "buttonIcon": {
            "type": "string",
            "default": ""
        },
        "buttonIconPosition": {
            "type": "string",
            "default": "right"
        },
        "buttonBorderWidth": {
            "type": "number",
            "default": 0
        },
        "buttonBorderColor": {
            "type": "string",
            "default": "#f48b2a"
        },
        "buttonBorderStyle": {
            "type": "string",
            "default": "solid"
        },
        "buttonHoverBgColor": {
            "type": "string",
            "default": ""
        },
        "buttonHoverTextColor": {
            "type": "string",
            "default": ""
        },
        "buttonHoverBorderColor": {
            "type": "string",
            "default": ""
        },
        "buttonBoxShadow": {
            "type": "boolean",
            "default": false
        },
        "buttonBoxShadowColor": {
            "type": "string",
            "default": "rgba(0, 0, 0, 0.15)"
        },
        "buttonBoxShadowBlur": {
            "type": "number",
            "default": 10
        },
        "buttonBoxShadowSpread": {
            "type": "number",
            "default": 0
        },
        "buttonBoxShadowOffsetX": {
            "type": "number",
            "default": 0
        },
        "buttonBoxShadowOffsetY": {
            "type": "number",
            "default": 4
        },
        "buttonHoverBoxShadow": {
            "type": "boolean",
            "default": true
        },
        "buttonHoverBoxShadowColor": {
            "type": "string",
            "default": ""
        },
        "buttonHoverBoxShadowBlur": {
            "type": "number",
            "default": 15
        },
        "buttonHoverBoxShadowSpread": {
            "type": "number",
            "default": 0
        },
        "buttonHoverBoxShadowOffsetX": {
            "type": "number",
            "default": 0
        },
        "buttonHoverBoxShadowOffsetY": {
            "type": "number",
            "default": 6
        },
        "buttonWidth": {
            "type": "string",
            "default": "auto"
        },
        "buttonWidthCustom": {
            "type": "number",
            "default": 200
        },
        "buttonAlignment": {
            "type": "string",
            "default": "left"
        },
        "buttonMarginTop": {
            "type": "number",
            "default": 0
        },
        "buttonMarginBottom": {
            "type": "number",
            "default": 0
        },
        "buttonMarginLeft": {
            "type": "number",
            "default": 0
        },
        "buttonMarginRight": {
            "type": "number",
            "default": 0
        },
        "buttonLetterSpacing": {
            "type": "number",
            "default": 0.5
        },
        "buttonLineHeight": {
            "type": "number",
            "default": 1.5
        },
        "buttonTransitionDuration": {
            "type": "number",
            "default": 0.3
        },
        "buttonHoverScale": {
            "type": "number",
            "default": 1.05
        },
        "buttonHoverTranslateY": {
            "type": "number",
            "default": -2
        },
        "buttonFontSizeMobile": {
            "type": "number",
            "default": 0
        },
        "buttonPaddingVerticalMobile": {
            "type": "number",
            "default": 0
        },
        "buttonPaddingHorizontalMobile": {
            "type": "number",
            "default": 0
        },
        "contentPadding": {
            "type": "number",
            "default": 32
        },
        "infoBlocks": {
            "type": "array",
            "default": []
        },
        "showOverlay": {
            "type": "boolean",
            "default": false
        },
        "overlayColor": {
            "type": "string",
            "default": "rgba(0, 0, 0, 0.3)"
        },
        "overlayOpacity": {
            "type": "number",
            "default": 0.3
        },
        "borderWidth": {
            "type": "number",
            "default": 0
        },
        "borderColor": {
            "type": "string",
            "default": "#e0e0e0"
        },
        "borderStyle": {
            "type": "string",
            "default": "solid"
        }
    },
    "textdomain": "twork-builder",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}

