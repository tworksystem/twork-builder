{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/em-doc-card",
	"version": "1.0.0",
	"title": "Specialist / Expert Card",
	"parent": [ "twork/em-doc-section" ],
	"category": "twork-builder",
	"icon": "id",
	"description": "Single Emergency Specialist card with photo, role, name, and specialty.",
	"keywords": [ "doctor", "specialist", "emergency", "card", "twork" ],
	"attributes": {
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"role": {
			"type": "string",
			"default": ""
		},
		"name": {
			"type": "string",
			"default": ""
		},
		"specialty": {
			"type": "string",
			"default": ""
		},
		"showSpecialty": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false
	},
	"example": {
		"attributes": {
			"imageUrl": "",
			"imageAlt": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"role": "",
			"name": "",
			"specialty": "",
			"showSpecialty": true
		}
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js"
}
