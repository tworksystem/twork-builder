{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/rad-process-section",
	"version": "1.0.0",
	"title": "Process Section",
	"category": "twork-builder",
	"icon": "yes-alt",
	"description": "Radiology visit workflow section with numbered process steps.",
	"keywords": [ "radiology", "process", "workflow", "steps", "twork" ],
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#fafafa"
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Your Visit Workflow"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2.2
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "center"
		},
		"columns": {
			"type": "number",
			"default": 4
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "number",
			"default": 20
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationType": {
			"type": "string",
			"default": "fade-up"
		},
		"animationDelay": {
			"type": "number",
			"default": 0
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#fafafa",
			"paddingTop": 80,
			"paddingBottom": 80,
			"containerMaxWidth": 1200,
			"containerPadding": 20,
			"showSectionTitle": true,
			"sectionTitle": "Your Visit Workflow",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2.2,
			"sectionTitleAlignment": "center",
			"columns": 4,
			"columnsTablet": 2,
			"columnsMobile": 1,
			"gap": 20,
			"animationOnScroll": true,
			"animationType": "fade-up",
			"animationDelay": 0
		},
		"innerBlocks": [
			{
				"name": "twork/rad-step-item",
				"attributes": {
					"iconClass": "far fa-calendar-check",
					"title": "Book",
					"description": "Schedule via phone or app."
				}
			},
			{
				"name": "twork/rad-step-item",
				"attributes": {
					"iconClass": "fas fa-user-nurse",
					"title": "Prepare",
					"description": "Fast or drink contrast (if needed)."
				}
			},
			{
				"name": "twork/rad-step-item",
				"attributes": {
					"iconClass": "fas fa-radiation",
					"title": "Scan",
					"description": "Quick and painless imaging."
				}
			},
			{
				"name": "twork/rad-step-item",
				"attributes": {
					"iconClass": "fas fa-file-medical-alt",
					"title": "Report",
					"description": "Digital report within 2 hours."
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
