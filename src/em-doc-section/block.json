{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/em-doc-section",
  "version": "1.0.0",
  "title": "Specialists Section",
  "category": "twork-builder",
  "icon": "groups",
  "description": "Emergency Specialists grid – section header with doctor cards (photo, role, name, specialty).",
  "keywords": [
    "emergency",
    "specialists",
    "doctors",
    "team",
    "twork"
  ],
  "attributes": {
    "backgroundColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "paddingTop": {
      "type": "number",
      "default": 80
    },
    "paddingBottom": {
      "type": "number",
      "default": 80
    },
    "containerMaxWidth": {
      "type": "number",
      "default": 1280
    },
    "containerPadding": {
      "type": "number",
      "default": 20
    },
    "gap": {
      "type": "number",
      "default": 30
    },
    "minColumnWidth": {
      "type": "number",
      "default": 240
    },
    "showSectionHeader": {
      "type": "boolean",
      "default": true
    },
    "sectionTitle": {
      "type": "string",
      "default": "Emergency Specialists"
    },
    "sectionTitleColor": {
      "type": "string",
      "default": "#212121"
    },
    "sectionTitleFontSize": {
      "type": "number",
      "default": 2.5
    },
    "sectionTitleFontWeight": {
      "type": "number",
      "default": 700
    },
    "showSectionSubtitle": {
      "type": "boolean",
      "default": false
    },
    "sectionSubtitle": {
      "type": "string",
      "default": ""
    },
    "sectionSubtitleColor": {
      "type": "string",
      "default": "#666666"
    },
    "sectionSubtitleFontSize": {
      "type": "number",
      "default": 1
    },
    "headerMaxWidth": {
      "type": "number",
      "default": 700
    },
    "headerMarginBottom": {
      "type": "number",
      "default": 40
    },
    "animationOnScroll": {
      "type": "boolean",
      "default": true
    },
    "animationType": {
      "type": "string",
      "default": "fade-up"
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}

