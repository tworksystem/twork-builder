{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/hero-section",
	"version": "1.0.0",
	"title": "Hero Section",
	"category": "twork-builder",
	"icon": "cover-image",
	"description": "Hero section with background and feature items.",
	"keywords": [
		"hero",
		"agriculture",
		"organic",
		"banner",
		"twork"
	],
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"taglineText": {
			"type": "string",
			"default": "Agriculture & Organic Farms"
		},
		"title": {
			"type": "string",
			"default": "Rooted in Nature,<br>Growing the Future"
		},
		"description": {
			"type": "string",
			"default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s."
		},
		"buttonText": {
			"type": "string",
			"default": "Explore More"
		},
		"buttonMediaUrl": {
			"type": "string",
			"default": ""
		},
		"buttonMediaId": {
			"type": "number"
		},
		"buttonMediaType": {
			"type": "string",
			"default": "image"
		},
		"showButtonIcon": {
			"type": "boolean",
			"default": true
		},
		"buttonIconType": {
			"type": "string",
			"default": "diagonal-arrow"
		},
		"buttonUrl": {
			"type": "string",
			"default": "#"
		},
		"buttonLinkTarget": {
			"type": "boolean",
			"default": false
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"overlayColor": {
			"type": "string",
			"default": "rgba(6, 42, 12, 0.55)"
		},
		"overlayGradient": {
			"type": "string",
			"default": "linear-gradient(135deg, rgba(143, 189, 69, 0.24) 0%, rgba(22, 46, 22, 0.1) 100%)"
		},
		"overlayGradientPreset": {
			"type": "string",
			"default": ""
		},
		"overlayOpacity": {
			"type": "number",
			"default": 1
		},
		"buttonBgColor": {
			"type": "string",
			"default": "#d9ea57"
		},
		"buttonTextColor": {
			"type": "string",
			"default": "#171b11"
		},
		"buttonBorderRadius": {
			"type": "number",
			"default": 16
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1240
		},
		"containerPadding": {
			"type": "number",
			"default": 24
		},
		"paddingTop": {
			"type": "number",
			"default": 110
		},
		"paddingBottom": {
			"type": "number",
			"default": 90
		},
		"paddingTopMobile": {
			"type": "number",
			"default": 92
		},
		"paddingBottomMobile": {
			"type": "number",
			"default": 34
		},
		"featuresGap": {
			"type": "number",
			"default": 18
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"taglineText": "Organic Agriculture & Regenerative Farms",
			"title": "Rooted in Nature,<br>Growing the Future",
			"description": "We combine soil health, biodiversity, and modern agronomy to deliver resilient harvests—without compromising the land we depend on.",
			"buttonText": "Explore Our Programs",
			"buttonMediaUrl": "",
			"buttonMediaType": "image",
			"showButtonIcon": true,
			"buttonIconType": "diagonal-arrow",
			"buttonUrl": "#",
			"buttonLinkTarget": false,
			"backgroundImage": "https://images.unsplash.com/photo-1625246333195-f8989295e467?auto=format&fit=crop&w=1920&q=80",
			"overlayColor": "rgba(6, 42, 12, 0.55)",
			"overlayGradient": "linear-gradient(135deg, rgba(143, 189, 69, 0.24) 0%, rgba(22, 46, 22, 0.1) 100%)",
			"overlayGradientPreset": "meadow-dawn",
			"overlayOpacity": 1,
			"buttonBgColor": "#d9ea57",
			"buttonTextColor": "#171b11",
			"buttonBorderRadius": 16,
			"containerMaxWidth": 1240,
			"containerPadding": 24,
			"paddingTop": 110,
			"paddingBottom": 90,
			"paddingTopMobile": 92,
			"paddingBottomMobile": 34,
			"featuresGap": 18
		},
		"innerBlocks": [
			{
				"name": "twork/hero-feature",
				"attributes": {
					"title": "Healthy Soil<br />Solutions",
					"iconVariant": "leaf"
				}
			},
			{
				"name": "twork/hero-feature",
				"attributes": {
					"title": "Pure Organic<br />Growth",
					"iconVariant": "drop"
				}
			},
			{
				"name": "twork/hero-feature",
				"attributes": {
					"title": "Nature-Driven<br />Innovation",
					"iconVariant": "sprout"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
