{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/insurance-partners-section",
	"title": "Insurance Partners Section",
	"category": "twork-builder",
	"description": "Insurance partners grid section with customizable cards for patient guide.",
	"keywords": [
		"insurance",
		"partners",
		"patient",
		"guide",
		"hospital",
		"twork"
	],
	"icon": "shield",
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"backgroundOverlay": {
			"type": "boolean",
			"default": false
		},
		"backgroundOverlayColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.5)"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 0.5
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"columns": {
			"type": "number",
			"default": 4
		},
		"columnsTablet": {
			"type": "number",
			"default": 3
		},
		"columnsMobile": {
			"type": "number",
			"default": 2
		},
		"gap": {
			"type": "number",
			"default": 20
		},
		"gridMarginTop": {
			"type": "number",
			"default": 40
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Insurance Partners"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2.2
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "center"
		},
		"showSectionSubtitle": {
			"type": "boolean",
			"default": true
		},
		"sectionSubtitle": {
			"type": "string",
			"default": "We accept cashless payments from leading insurance providers."
		},
		"sectionSubtitleColor": {
			"type": "string",
			"default": "#666666"
		},
		"sectionSubtitleFontSize": {
			"type": "number",
			"default": 1.05
		},
		"sectionHeaderMaxWidth": {
			"type": "number",
			"default": 700
		},
		"sectionHeaderMarginBottom": {
			"type": "number",
			"default": 20
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"hoverEffect": {
			"type": "boolean",
			"default": true
		},
		"hoverTranslateY": {
			"type": "number",
			"default": -5
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#ffffff",
			"backgroundImage": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"backgroundOverlay": false,
			"backgroundOverlayColor": "rgba(0, 0, 0, 0.5)",
			"backgroundOverlayOpacity": 0.5,
			"paddingTop": 80,
			"paddingBottom": 80,
			"columns": 4,
			"columnsTablet": 3,
			"columnsMobile": 2,
			"gap": 20,
			"gridMarginTop": 40,
			"showSectionTitle": true,
			"sectionTitle": "Insurance Partners",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2.2,
			"sectionTitleFontWeight": 700,
			"sectionTitleAlignment": "center",
			"showSectionSubtitle": true,
			"sectionSubtitle": "We accept cashless payments from leading insurance providers.",
			"sectionSubtitleColor": "#666666",
			"sectionSubtitleFontSize": 1.05,
			"sectionHeaderMaxWidth": 700,
			"sectionHeaderMarginBottom": 20,
			"containerMaxWidth": 1200,
			"containerPadding": 20,
			"hoverEffect": true,
			"hoverTranslateY": -5
		},
		"innerBlocks": [
			{
				"name": "twork/insurance-partner-item",
				"attributes": {
					"partnerName": "AIA Myanmar",
					"iconClass": "fas fa-shield-alt"
				}
			},
			{
				"name": "twork/insurance-partner-item",
				"attributes": {
					"partnerName": "Prudential",
					"iconClass": "fas fa-umbrella"
				}
			},
			{
				"name": "twork/insurance-partner-item",
				"attributes": {
					"partnerName": "Manulife",
					"iconClass": "fas fa-leaf"
				}
			},
			{
				"name": "twork/insurance-partner-item",
				"attributes": {
					"partnerName": "GGI Insurance",
					"iconClass": "fas fa-building"
				}
			},
			{
				"name": "twork/insurance-partner-item",
				"attributes": {
					"partnerName": "IKBZ Insurance",
					"iconClass": "fas fa-landmark"
				}
			},
			{
				"name": "twork/insurance-partner-item",
				"attributes": {
					"partnerName": "CB Insurance",
					"iconClass": "fas fa-hand-holding-heart"
				}
			},
			{
				"name": "twork/insurance-partner-item",
				"attributes": {
					"partnerName": "MGA Insurance",
					"iconClass": "fas fa-globe-asia"
				}
			},
			{
				"name": "twork/insurance-partner-item",
				"attributes": {
					"partnerName": "Others",
					"iconClass": "fas fa-file-medical"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
