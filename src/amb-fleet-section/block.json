{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "twork/amb-fleet-section",
  "version": "1.0.0",
  "title": "Ambulance Fleet Section",
  "category": "twork-builder",
  "icon": "car",
  "description": "Ambulance fleet section with header and fleet cards grid (e.g. ALS/BLS).",
  "keywords": ["ambulance", "fleet", "vehicle", "emergency", "twork"],
  "attributes": {
    "backgroundColor": {
      "type": "string",
      "default": "#f1f5f9"
    },
    "backgroundImage": {
      "type": "string",
      "default": ""
    },
    "backgroundImageId": {
      "type": "number"
    },
    "backgroundOverlay": {
      "type": "boolean",
      "default": false
    },
    "backgroundOverlayColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.5)"
    },
    "backgroundOverlayOpacity": {
      "type": "number",
      "default": 0.5
    },
    "paddingTop": {
      "type": "number",
      "default": 100
    },
    "paddingBottom": {
      "type": "number",
      "default": 150
    },
    "clipPath": {
      "type": "boolean",
      "default": true
    },
    "clipPathPolygon": {
      "type": "string",
      "default": "0 0, 100% 0, 100% 95%, 0 100%"
    },
    "columns": {
      "type": "number",
      "default": 2
    },
    "columnsTablet": {
      "type": "number",
      "default": 2
    },
    "columnsMobile": {
      "type": "number",
      "default": 1
    },
    "gap": {
      "type": "number",
      "default": 50
    },
    "containerMaxWidth": {
      "type": "number",
      "default": 1200
    },
    "containerPadding": {
      "type": "number",
      "default": 20
    },
    "showSectionTitle": {
      "type": "boolean",
      "default": true
    },
    "sectionTitle": {
      "type": "string",
      "default": "Our Fleet"
    },
    "sectionTitleColor": {
      "type": "string",
      "default": "#0f172a"
    },
    "sectionTitleFontSize": {
      "type": "number",
      "default": 2.5
    },
    "sectionTitleFontWeight": {
      "type": "number",
      "default": 900
    },
    "sectionTitleAlignment": {
      "type": "string",
      "default": "center"
    },
    "sectionTitleMarginBottom": {
      "type": "number",
      "default": 15
    },
    "showSectionSubtitle": {
      "type": "boolean",
      "default": true
    },
    "sectionSubtitle": {
      "type": "string",
      "default": "We dispatch the right vehicle for your medical condition."
    },
    "sectionSubtitleColor": {
      "type": "string",
      "default": "#666666"
    },
    "sectionSubtitleFontSize": {
      "type": "number",
      "default": 1.1
    },
    "sectionSubtitleMarginBottom": {
      "type": "number",
      "default": 60
    },
    "animationOnScroll": {
      "type": "boolean",
      "default": true
    },
    "animationDelay": {
      "type": "number",
      "default": 100
    },
    "animationType": {
      "type": "string",
      "default": "fadeInUp"
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"]
  },
  "textdomain": "twork-builder",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}
