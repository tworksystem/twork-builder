{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "twork/visiting-info-section",
	"title": "Visiting Information Section",
	"category": "twork-builder",
	"description": "Visiting hours section with two-column layout (content + image) for patient guide.",
	"keywords": [
		"visiting",
		"hours",
		"patient",
		"guide",
		"hospital",
		"wards",
		"twork"
	],
	"icon": "clock",
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#f8f9fa"
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"backgroundOverlay": {
			"type": "boolean",
			"default": false
		},
		"backgroundOverlayColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.5)"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 0.5
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"paddingTopMobile": {
			"type": "number",
			"default": 60
		},
		"paddingBottomMobile": {
			"type": "number",
			"default": 60
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Visiting Information"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2
		},
		"sectionTitleFontSizeMobile": {
			"type": "number",
			"default": 1.6
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleMarginBottom": {
			"type": "number",
			"default": 20
		},
		"showSectionDescription": {
			"type": "boolean",
			"default": true
		},
		"sectionDescription": {
			"type": "string",
			"default": "We recognize the importance of family and friends in the healing process. However, to ensure patient rest and safety, please adhere to our visiting hours."
		},
		"sectionDescriptionColor": {
			"type": "string",
			"default": "#666666"
		},
		"sectionDescriptionFontSize": {
			"type": "number",
			"default": 1
		},
		"sectionDescriptionMarginBottom": {
			"type": "number",
			"default": 30
		},
		"showImage": {
			"type": "boolean",
			"default": true
		},
		"imageUrl": {
			"type": "string",
			"default": "https://images.unsplash.com/photo-1538108149393-fbbd81895907?auto=format&fit=crop&q=80&w=800"
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": "Reception"
		},
		"imageBorderRadius": {
			"type": "number",
			"default": 12
		},
		"imageBoxShadow": {
			"type": "boolean",
			"default": true
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"layoutGap": {
			"type": "number",
			"default": 50
		},
		"layoutGapMobile": {
			"type": "number",
			"default": 30
		},
		"imageFirstOnMobile": {
			"type": "boolean",
			"default": false
		},
		"hoursCardBgColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"hoursCardPadding": {
			"type": "number",
			"default": 40
		},
		"hoursCardBorderRadius": {
			"type": "number",
			"default": 12
		},
		"hoursCardBoxShadow": {
			"type": "boolean",
			"default": true
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationType": {
			"type": "string",
			"default": "fadeInUp"
		},
		"animationDelay": {
			"type": "number",
			"default": 100
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#f8f9fa",
			"backgroundImage": "https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?auto=format&fit=crop&w=1200&q=80",
			"backgroundOverlay": false,
			"backgroundOverlayColor": "rgba(0, 0, 0, 0.5)",
			"backgroundOverlayOpacity": 0.5,
			"paddingTop": 80,
			"paddingBottom": 80,
			"paddingTopMobile": 60,
			"paddingBottomMobile": 60,
			"showSectionTitle": true,
			"sectionTitle": "Visiting Information",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2,
			"sectionTitleFontSizeMobile": 1.6,
			"sectionTitleFontWeight": 700,
			"sectionTitleMarginBottom": 20,
			"showSectionDescription": true,
			"sectionDescription": "We recognize the importance of family and friends in the healing process. However, to ensure patient rest and safety, please adhere to our visiting hours.",
			"sectionDescriptionColor": "#666666",
			"sectionDescriptionFontSize": 1,
			"sectionDescriptionMarginBottom": 30,
			"showImage": true,
			"imageUrl": "https://images.unsplash.com/photo-1538108149393-fbbd81895907?auto=format&fit=crop&q=80&w=800",
			"imageAlt": "Reception",
			"imageBorderRadius": 12,
			"imageBoxShadow": true,
			"containerMaxWidth": 1200,
			"containerPadding": 20,
			"layoutGap": 50,
			"layoutGapMobile": 30,
			"imageFirstOnMobile": false,
			"hoursCardBgColor": "#ffffff",
			"hoursCardPadding": 40,
			"hoursCardBorderRadius": 12,
			"hoursCardBoxShadow": true,
			"animationOnScroll": true,
			"animationType": "fadeInUp",
			"animationDelay": 100
		},
		"innerBlocks": [
			{
				"name": "twork/visiting-hours-item",
				"attributes": {
					"wardName": "General Ward",
					"timeSlot": "10:00 AM – 8:00 PM",
					"iconClass": "fas fa-procedures"
				}
			},
			{
				"name": "twork/visiting-hours-item",
				"attributes": {
					"wardName": "ICU / CCU",
					"timeSlot": "11:00 AM – 12:00 PM",
					"iconClass": "fas fa-heartbeat"
				}
			},
			{
				"name": "twork/visiting-hours-item",
				"attributes": {
					"wardName": "Private Rooms",
					"timeSlot": "8:00 AM – 9:00 PM",
					"iconClass": "fas fa-user-md"
				}
			},
			{
				"name": "twork/visiting-hours-item",
				"attributes": {
					"wardName": "NICU (Parents)",
					"timeSlot": "24 Hours Allowed",
					"iconClass": "fas fa-baby"
				}
			}
		]
	},
	"textdomain": "twork-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
